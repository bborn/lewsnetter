<%#
  Lewsnetter override of bullet_train-themes-light billing/_pricing_table.
  Single-plan ($10/mo Pro) centered card. Matches DESIGN.md:
  - Geist Sans / Geist Mono via global typography
  - Orange #EA580C primary CTA via .button (theme-orange)
  - No icons. Text-only bullets. Hairline borders. 8px radius.
  - Hero-style spacing; the kind of page a paying customer doesn't flinch at.

  Receives:
    prices — Array<Billing::Price>. We render exactly one card.
      Prefers the highlighted price; falls back to the first.
%>

<% price = (prices.find(&:highlight?) || prices.first) %>
<% return unless price %>

<div class="w-full flex flex-col items-center py-12 px-4">
  <article class="w-full max-w-[480px] bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg">
    <%# Header: eyebrow label + description %>
    <header class="px-10 pt-10 pb-6 text-center">
      <div class="font-mono text-[11px] font-medium uppercase tracking-[0.06em] text-zinc-500 dark:text-zinc-400">
        <%= price.product.label_string %>
      </div>
      <% if price.product.description.present? %>
        <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
          <%= price.product.description %>
        </p>
      <% end %>
    </header>

    <%# Price + CTA — the editorial moment %>
    <div class="px-10 pb-10 text-center border-b border-zinc-200 dark:border-zinc-800">
      <div class="flex items-baseline justify-center gap-1">
        <span class="text-[56px] leading-none font-semibold tracking-[-0.025em] text-zinc-950 dark:text-zinc-50 tabular-nums">
          <%= smaller_currency_symbol(number_to_currency(price.currency_amount, precision: 0, locale: :en)) %>
        </span>
        <span class="font-mono text-sm text-zinc-500 dark:text-zinc-400">/mo</span>
      </div>
      <div class="mt-2 font-mono text-[11px] uppercase tracking-[0.06em] text-zinc-500 dark:text-zinc-400">
        per team · billed monthly
      </div>

      <div class="mt-8">
        <%= render "account/billing/subscriptions/new_button", price: price, classes: "button w-full justify-center text-base py-3" %>
      </div>
    </div>

    <%# Features %>
    <% if price.product.features.present? %>
      <ul class="px-10 py-8 space-y-3">
        <% price.product.features.each do |feature| %>
          <li class="flex items-start gap-3 text-[15px] leading-relaxed text-zinc-700 dark:text-zinc-300">
            <span aria-hidden="true" class="select-none text-zinc-400 dark:text-zinc-600 leading-relaxed">•</span>
            <span><%= feature.html_safe %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </article>

  <p class="mt-6 font-mono text-[11px] uppercase tracking-[0.06em] text-zinc-500 dark:text-zinc-400 text-center">
    Cancel anytime · Secure checkout via Stripe
  </p>
</div>
