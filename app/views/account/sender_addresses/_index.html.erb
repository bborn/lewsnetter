<% sender_addresses = sender_addresses.accessible_by(current_ability) %>
<% team = @team %>
<% context ||= team %>
<% collection ||= :sender_addresses %>
<% hide_actions ||= false %>
<% hide_back ||= false %>

<% pagy ||= nil %>
<% pagy, sender_addresses = pagy(sender_addresses, page_param: :sender_addresses_page) unless pagy %>

<%= action_model_select_controller do %>
  <% cable_ready_updates_for context, collection do %>
    <%= render 'account/shared/box', pagy: pagy do |box| %>
      <% box.title t(".contexts.#{context.class.name.underscore}.header") %>
      <% box.description do %>
        <%= t(".contexts.#{context.class.name.underscore}.description#{"_empty" unless sender_addresses.any?}") %>
        <%= render "shared/limits/index", model: sender_addresses.model %>
      <% end %>

      <% box.table do %>
        <% if sender_addresses.any? %>
          <table class="table">
            <thead>
              <tr>
                <%= render "shared/tables/select_all" %>
                <th><%= t('.fields.email.heading') %></th>
                <th><%= t('.fields.name.heading') %></th>
                <%# Single Status column replacing the previous redundant
                    Verified + SES Status pair (U12). %>
                <th>Status</th>
                <%# 🚅 super scaffolding will insert new field headers above this line. %>
                <th><%= t('.fields.created_at.heading') %></th>
                <th class="text-right"></th>
              </tr>
            </thead>
            <tbody>
              <%= render partial: 'account/sender_addresses/sender_address', collection: sender_addresses %>
            </tbody>
          </table>
        <% elsif context == team && can?(:create, SenderAddress.new(team: team)) %>
          <div class="text-center py-12 px-6">
            <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">No senders yet</div>
            <h3 class="text-[18px] font-semibold text-zinc-900 dark:text-zinc-100 mb-2">Add a from-address</h3>
            <p class="text-zinc-500 dark:text-zinc-400 max-w-md mx-auto mb-6">
              Recipients see this address in their inbox. Each must be verified
              with Amazon SES before it can send.
            </p>
            <%= link_to "Add sender address →", [:new, :account, team, :sender_address], class: "button" %>
          </div>
        <% end %>
      <% end %>

      <% box.actions do %>
        <% unless hide_actions %>
          <% if context == team %>
            <% if can? :create, SenderAddress.new(team: team) %>
              <%= link_to t('.buttons.new'), [:new, :account, team, :sender_address], class: "#{first_button_primary(:sender_address)} new" %>
            <% end %>
          <% end %>

          <%# 🚅 super scaffolding will insert new targets one parent action model buttons above this line. %>
          <%# 🚅 super scaffolding will insert new bulk action model buttons above this line. %>
          <%= render "shared/bulk_action_select" if sender_addresses.any? %>

          <% unless hide_back %>
            <%= link_to t('global.buttons.back'), [:account, context], class: "#{first_button_primary(:sender_address)} back" %>
          <% end %>
        <% end %>
      <% end %>

      <% box.raw_footer do %>
        <%# 🚅 super scaffolding will insert new action model index views above this line. %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
