<%
  short_id = @sender_address.respond_to?(:obfuscated_id) ? @sender_address.obfuscated_id : @sender_address.id
  verified = @sender_address.verified?
%>
<%= render 'account/shared/page' do |page| %>
  <%# Editorial header below serves as the title; skip the default H1. %>
  <% page.title nil %>
  <% page.body do %>
    <%= cable_ready_updates_for @sender_address do %>

      <%# ============================================================
          Editorial header — eyebrow + email + status pill + actions.
          ============================================================ %>
      <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl mb-6 p-10">
        <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-3 flex items-center gap-2">
          <span>Sender · <%= short_id %></span>
          <span class="text-zinc-300 dark:text-zinc-700">·</span>
          <%= sender_address_status_pill(@sender_address) %>
        </div>
        <h1 class="text-zinc-900 dark:text-zinc-50 font-semibold text-[32px] leading-tight tracking-tight mb-1 break-all">
          <%= @sender_address.email %>
        </h1>
        <p class="font-mono text-[13px] text-zinc-500 dark:text-zinc-400 mb-7">
          <% if @sender_address.name.present? %>
            <%= @sender_address.name %> · From-address for campaign sends
          <% else %>
            From-address for campaign sends
          <% end %>
        </p>
        <div class="flex items-center gap-2 flex-wrap">
          <% if can? :edit, @sender_address %>
            <%= link_to "Edit", [:edit, :account, @sender_address], class: "button-secondary" %>
          <% end %>
          <% if can? :destroy, @sender_address %>
            <%= button_to "Delete", [:account, @sender_address], method: :delete,
                  class: "button-secondary button-danger",
                  data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@sender_address)) } %>
          <% end %>
          <%= link_to "Back to senders", [:account, @team, :sender_addresses], class: "button-light" %>
        </div>
      </div>

      <%# ============================================================
          Verification card — primary action when unverified, quiet
          re-check link when already verified.
          ============================================================ %>
      <% if verified %>
        <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg p-6 mb-6 flex items-center justify-between gap-4 flex-wrap">
          <div>
            <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1">Verification</div>
            <p class="text-zinc-700 dark:text-zinc-300 text-sm">
              SES recognizes this address. Campaigns can send from it.
            </p>
          </div>
          <% if can? :update, @sender_address %>
            <%= button_to "Re-check with SES",
                  recheck_account_sender_address_path(@sender_address),
                  method: :post,
                  class: "button-secondary" %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-900/60 rounded-lg p-6 mb-6">
          <div class="font-mono text-[11px] uppercase tracking-widest text-amber-700 dark:text-amber-400 mb-2">Verification pending</div>
          <h2 class="text-zinc-900 dark:text-zinc-50 font-semibold text-lg mb-2">Verify this address with Amazon SES</h2>
          <p class="text-zinc-700 dark:text-zinc-300 text-sm mb-4 max-w-xl">
            We'll ask SES to send a confirmation link to <span class="font-mono"><%= @sender_address.email %></span>.
            Click it, then come back and re-check.
          </p>
          <% if can? :update, @sender_address %>
            <div class="flex items-center gap-2 flex-wrap">
              <%= button_to "Send verification email",
                    verify_with_ses_account_sender_address_path(@sender_address),
                    method: :post,
                    class: "button" %>
              <%= button_to "Re-check with SES",
                    recheck_account_sender_address_path(@sender_address),
                    method: :post,
                    class: "button-secondary" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ============================================================
          Details — clean key/value card with mono caps labels.
          ============================================================ %>
      <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden">
        <div class="px-6 py-4 flex items-baseline justify-between border-b border-zinc-200 dark:border-zinc-800">
          <h2 class="text-[18px] font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">Details</h2>
          <% if can? :edit, @sender_address %>
            <%= link_to "Edit sender", [:edit, :account, @sender_address], class: "card-action" %>
          <% end %>
        </div>
        <dl class="grid grid-cols-1 md:grid-cols-2">
          <div class="px-6 py-4 border-b md:border-b border-zinc-200 dark:border-zinc-800 md:border-r">
            <dt class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1">Email</dt>
            <dd class="font-sans text-zinc-900 dark:text-zinc-100 break-all"><%= @sender_address.email %></dd>
          </div>
          <div class="px-6 py-4 border-b border-zinc-200 dark:border-zinc-800">
            <dt class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1">Display name</dt>
            <dd class="font-sans <%= @sender_address.name.present? ? 'text-zinc-900 dark:text-zinc-100' : 'text-zinc-400 italic' %>">
              <%= @sender_address.name.presence || "Not set" %>
            </dd>
          </div>
          <div class="px-6 py-4 md:border-r border-zinc-200 dark:border-zinc-800">
            <dt class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1">SES status</dt>
            <dd><%= sender_address_status_pill(@sender_address) %></dd>
          </div>
          <div class="px-6 py-4 border-t md:border-t-0 border-zinc-200 dark:border-zinc-800">
            <dt class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1">Added</dt>
            <dd class="font-mono text-[13px] text-zinc-700 dark:text-zinc-300">
              <%= @sender_address.created_at.strftime("%b %-d, %Y at %-l:%M %p") %>
            </dd>
          </div>
        </dl>
      </div>

      <%# 🚅 super scaffolding will insert new action model index views above this line. %>
    <% end %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>
