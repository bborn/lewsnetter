<%= render 'account/shared/page' do |page| %>
  <% page.title t('.section', teams_possessive: possessive_string(@team.name)) %>
  <% page.body do %>
    <%= render 'account/email_sending/paywall_notice' %>

    <%= render 'account/shared/box', divider: true do |box| %>
      <% box.title t('.header') %>
      <% box.description do %>
        <% if @ses_configuration.verified? %>
          <%= t('.verified_description',
                last_verified_at: @ses_configuration.last_verified_at ? l(@ses_configuration.last_verified_at, format: :short) : "—",
                quota_sent: @ses_configuration.quota_sent_last_24h || 0,
                quota_max: @ses_configuration.quota_max_send_24h || "—") %>
        <% elsif @ses_configuration.failed? %>
          <%= t('.failed_description', error: @ses_configuration.try(:last_verification_error) || "see logs") %>
        <% elsif @ses_configuration.verifying? %>
          <%= t('.verifying_description') %>
        <% else %>
          <%= t('.unconfigured_description') %>
        <% end %>
      <% end %>

      <% box.body do %>
        <% with_attribute_settings object: @ses_configuration, strategy: :label do %>
          <%= render 'shared/attributes/text', attribute: :status,
                     value: t("email_sending.statuses.#{@ses_configuration.status}", default: @ses_configuration.status.to_s.humanize) %>
          <%= render 'shared/attributes/text', attribute: :region %>
          <% if @ses_configuration.configured? %>
            <%= render 'shared/attributes/text', attribute: :encrypted_access_key_id,
                       value: "•••• #{@ses_configuration.access_key_id_last_four}" %>
          <% end %>
          <%= render 'shared/attributes/text', attribute: :sandbox,
                     value: t("email_sending.sandbox_states.#{@ses_configuration.sandbox? ? "yes" : "no"}") %>
          <% if @ses_configuration.quota_max_send_24h %>
            <%= render 'shared/attributes/text', attribute: :quota,
                       value: "#{@ses_configuration.quota_sent_last_24h.to_i} / #{@ses_configuration.quota_max_send_24h}" %>
          <% end %>
          <% if @ses_configuration.last_verified_at %>
            <%= render 'shared/attributes/text', attribute: :last_verified_at,
                       value: l(@ses_configuration.last_verified_at, format: :short) %>
          <% end %>
        <% end %>
      <% end %>

      <% box.actions do %>
        <% if @ses_configuration.configured? && can?(:manage, @ses_configuration) %>
          <%= button_to t('.buttons.verify'),
                        account_team_verify_email_sending_path(@team),
                        method: :post, class: first_button_primary %>
        <% end %>
        <%= link_to t('global.buttons.back'), [:account, @team], class: "button-secondary" %>
      <% end %>
    <% end %>

    <%= render 'account/email_sending/form', team: @team, ses_configuration: @ses_configuration %>

    <%# SNS bounce/complaint/delivery webhook wiring — auto-provisioned via
        Ses::SnsAutoWire using the team's existing SES IAM creds. Replaces
        the old manual "paste three ARNs you copied from the AWS console"
        flow. Idempotent — the same button doubles as "re-verify / repair". %>
    <% if @ses_configuration.configured? %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title t('email_sending.show.sections.sns.header') %>
        <% box.description t('email_sending.show.sections.sns.description',
                            webhook_url: (ENV["BASE_URL"].presence || request.base_url).chomp("/") + "/webhooks/ses/sns") %>

        <% box.body do %>
          <% if @ses_configuration.sns_bounce_topic_arn.present? %>
            <% with_attribute_settings object: @ses_configuration, strategy: :label do %>
              <%= render 'shared/attributes/text', attribute: :sns_bounce_topic_arn,
                         value: @ses_configuration.sns_bounce_topic_arn %>
              <%= render 'shared/attributes/text', attribute: :sns_complaint_topic_arn,
                         value: @ses_configuration.sns_complaint_topic_arn %>
              <% if @ses_configuration.respond_to?(:sns_delivery_topic_arn) && @ses_configuration.sns_delivery_topic_arn.present? %>
                <p class="attribute-row">
                  <span class="attribute-label">SNS Delivery Topic ARN</span>
                  <span class="attribute-value"><%= @ses_configuration.sns_delivery_topic_arn %></span>
                </p>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">
              <%= t('email_sending.show.sections.sns.not_configured',
                    default: "Not configured yet. Click the button below and Lewsnetter will create the SNS topics + SES configuration set on your behalf.") %>
            </p>
          <% end %>
        <% end %>

        <% box.actions do %>
          <% if can?(:manage, @ses_configuration) %>
            <%= button_to (@ses_configuration.sns_bounce_topic_arn.present? ?
                            t('email_sending.buttons.reverify_sns', default: "Re-verify SNS wiring") :
                            t('email_sending.buttons.setup_sns', default: "Set up SNS automatically")),
                          account_team_verify_sns_email_sending_path(@team),
                          method: :post, class: first_button_primary %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <% if @verifier_result&.identities&.any? %>
      <%= render 'account/email_sending/verified_identities',
                 team: @team, identities: @verifier_result.identities %>
    <% end %>
  <% end %>
<% end %>
