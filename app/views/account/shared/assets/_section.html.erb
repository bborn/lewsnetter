<%#
  Assets section for any form that has_many_attached :assets — currently
  EmailTemplate and Campaign. Renders:
    - a multi-file image picker styled like the CSV input on
      account/subscribers/imports/new
    - a list of already-attached assets with:
        - 60x60 thumbnail
        - filename
        - the public-facing URL (rails_storage_proxy_url) + Copy URL button
        - a Delete link that hits the destroy_asset member action

  Required locals:
    form     — the FormBuilder we're inside
    resource — the parent record (EmailTemplate or Campaign). Used to
               look up @template.assets / @campaign.assets and to build
               the destroy_asset path (asset_account_email_template_path
               vs asset_account_campaign_path).

  We deliberately use `rails_storage_proxy_url(blob, host: …)` rather
  than `url_for(blob)`:
    - url_for produces a signed, time-expiring URL — useless for emails
      that recipients open days/weeks later.
    - rails_storage_proxy_url is non-expiring + lives on our domain.
      Trade-off: bytes flow through Rails on every request. When we
      configure the R2 bucket for public reads we can swap to a direct
      r2.cloudflarestorage.com URL.
%>

<%
  resource_name = resource.class.model_name.singular # "email_template" | "campaign"
  destroy_asset_path = case resource
  when EmailTemplate
    ->(attachment) { asset_account_email_template_path(resource, asset_id: attachment.id) }
  when Campaign
    ->(attachment) { asset_account_campaign_path(resource, asset_id: attachment.id) }
  else
    raise "Unsupported asset host: #{resource.class}"
  end
%>

<section class="mb-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg p-6">
  <header class="mb-5">
    <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1">Assets</div>
    <h2 class="text-[18px] font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 mb-1">Hosted images</h2>
    <p class="text-sm text-zinc-500 dark:text-zinc-400">
      Upload images to Cloudflare R2. Drag and drop also works directly in the
      markdown editor above — drop a file into the body and we'll splice in
      <code class="font-mono text-[12px] text-zinc-700 dark:text-zinc-300">![alt](url)</code>.
    </p>
  </header>

  <div class="mb-5">
    <%= form.label :assets, "Add images", class: "block font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-2" %>
    <div>
      <%# multipart: true is set on the surrounding form_with via html: option;
          we still pass it on the file input so screen-readers + native validation
          both treat this as a true file picker. %>
      <%= form.file_field :assets,
            multiple: true,
            accept: "image/*",
            class: "block w-full text-sm rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-700 dark:text-zinc-300 px-3 py-2 file:mr-3 file:rounded-md file:border-0 file:bg-primary-600 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-white hover:file:bg-primary-700" %>
    </div>
    <p class="mt-2 text-[12px] text-zinc-500 dark:text-zinc-400">
      Images only, 5MB max each. Multiple selection allowed.
    </p>
  </div>

  <%# Only render attachments whose underlying ::Attachment row is persisted.
      When a validation fails mid-update the in-memory has_many_attached
      buffer contains the freshly-built (unsaved) attachment, and calling
      rails_storage_proxy_url on its blob raises "Cannot get a signed_id
      for a new record". %>
  <% persisted_attachments = resource.persisted? ? resource.assets.attachments.select(&:persisted?) : [] %>
  <% if persisted_attachments.any? %>
    <ul class="space-y-3" data-testid="assets-list">
      <% persisted_attachments.each do |attachment| %>
        <% blob = attachment.blob %>
        <% public_url = rails_storage_proxy_url(blob) %>
        <li class="flex items-start gap-3 p-3 border rounded-md bg-zinc-50 dark:bg-zinc-950/40 border-zinc-200 dark:border-zinc-800"
            data-controller="clipboard">
          <%# Thumbnail. Tailwind's object-cover keeps the aspect ratio while
              filling the box; for non-image blobs (shouldn't happen given
              the model validator) we'd render a generic icon, but the
              accept="image/*" + model validation gate covers us. %>
          <div class="shrink-0 w-[60px] h-[60px] rounded overflow-hidden bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
            <%= image_tag public_url,
                  alt: blob.filename.to_s,
                  class: "w-full h-full object-cover",
                  loading: "lazy" %>
          </div>

          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate" title="<%= blob.filename %>">
              <%= blob.filename %>
            </p>
            <p class="font-mono text-[11px] text-zinc-500 dark:text-zinc-400 mt-0.5 tabular-nums">
              <%= number_to_human_size(blob.byte_size) %>
            </p>
            <div class="mt-2 flex items-center gap-2">
              <code class="flex-1 min-w-0 truncate text-[12px] font-mono px-2 py-1 rounded bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300"
                    data-clipboard-target="source"><%= public_url %></code>
              <button type="button"
                      data-clipboard-target="button"
                      data-action="click->clipboard#copy"
                      class="shrink-0 button-secondary button-smaller">
                Copy URL
              </button>
            </div>
          </div>

          <%# We use link_to + turbo_method:delete (not button_to) so the
              delete control DOESN'T render a nested <form>. The whole
              Assets section is inside the outer form_with, and Rails
              7.1+ button_to inside a form silently emits its inputs
              without the wrapping form — clicking the bare button then
              submits the OUTER form (a PATCH to the resource) instead
              of the asset DELETE. A Turbo-enhanced link sidesteps this
              by going out via fetch instead of form submission. %>
          <div class="shrink-0">
            <%= link_to "Delete",
                  destroy_asset_path.call(attachment),
                  data: { turbo_method: :delete, turbo_confirm: "Delete this asset? This cannot be undone." },
                  class: "button-secondary button-smaller button-danger" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% elsif resource.persisted? %>
    <p class="text-sm text-zinc-500 dark:text-zinc-400">
      <span class="font-mono text-[11px] uppercase tracking-widest mr-1">Empty</span>
      No assets uploaded yet. Add files above or drop them into the markdown editor.
    </p>
  <% else %>
    <p class="text-sm text-zinc-500 dark:text-zinc-400">
      <span class="font-mono text-[11px] uppercase tracking-widest mr-1">Pending save</span>
      Save this <%= resource_name.humanize.downcase %> first to start uploading assets.
    </p>
  <% end %>
</section>
