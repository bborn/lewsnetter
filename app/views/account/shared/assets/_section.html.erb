<%#
  Uploaded images list for any form that has_many_attached :assets —
  currently EmailTemplate and Campaign. The PRIMARY way to add an image
  is now inside the editor itself (drop / paste / toolbar button). This
  partial just gives authors a way to see + delete images they've
  uploaded across sessions and falls back to a multi-file picker for
  unusual flows. Collapsed by default so it doesn't compete with the
  editor surface.

  Required locals:
    form     — the FormBuilder we're inside
    resource — the parent record (EmailTemplate or Campaign).

  We deliberately use `rails_storage_proxy_url(blob)` rather than
  `url_for(blob)` because url_for produces a signed, time-expiring URL —
  useless for emails recipients open days or weeks later.
%>

<%
  resource_name = resource.class.model_name.singular # "email_template" | "campaign"
  destroy_asset_path = case resource
  when EmailTemplate
    ->(attachment) { asset_account_email_template_path(resource, asset_id: attachment.id) }
  when Campaign
    ->(attachment) { asset_account_campaign_path(resource, asset_id: attachment.id) }
  else
    raise "Unsupported asset host: #{resource.class}"
  end

  # Only render attachments whose underlying ::Attachment row is persisted.
  # When a validation fails mid-update the in-memory has_many_attached
  # buffer contains the freshly-built (unsaved) attachment, and calling
  # rails_storage_proxy_url on its blob raises "Cannot get a signed_id
  # for a new record".
  persisted_attachments = resource.persisted? ? resource.assets.attachments.select(&:persisted?) : []
%>

<details class="mb-6 rounded-md border border-zinc-200 dark:border-zinc-800 bg-zinc-50/60 dark:bg-zinc-950/40 group">
  <summary class="cursor-pointer select-none px-4 py-3 flex items-center justify-between hover:bg-zinc-100/60 dark:hover:bg-zinc-800/40 transition-colors">
    <div>
      <span class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Uploaded images</span>
      <% if persisted_attachments.any? %>
        <span class="ml-2 font-mono text-[11px] text-zinc-400 dark:text-zinc-500 tabular-nums"><%= persisted_attachments.size %></span>
      <% end %>
    </div>
    <span class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 group-open:hidden">Show ▾</span>
    <span class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 hidden group-open:inline">Hide ▴</span>
  </summary>

  <div class="px-4 pt-3 pb-4 border-t border-zinc-200 dark:border-zinc-800 space-y-4">
    <p class="text-[13px] text-zinc-500 dark:text-zinc-400">
      Drop, paste, or click the image button inside the editor to add a new image. This list shows everything previously uploaded for this <%= resource_name.humanize.downcase %>.
    </p>

    <% if resource.persisted? %>
      <div>
        <%= form.label :assets, "Upload from disk", class: "block font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-2" %>
        <%= form.file_field :assets,
              multiple: true,
              accept: "image/*",
              class: "block w-full text-sm rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-700 dark:text-zinc-300 px-3 py-2 file:mr-3 file:rounded-md file:border-0 file:bg-primary-600 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-white hover:file:bg-primary-700" %>
        <p class="mt-2 text-[12px] text-zinc-500 dark:text-zinc-400">Images only, 5MB max each.</p>
      </div>
    <% end %>

    <% if persisted_attachments.any? %>
      <ul class="space-y-3" data-testid="assets-list">
        <% persisted_attachments.each do |attachment| %>
          <% blob = attachment.blob %>
          <% public_url = rails_storage_proxy_url(blob) %>
          <li class="flex items-start gap-3 p-3 border rounded-md bg-white dark:bg-zinc-900 border-zinc-200 dark:border-zinc-800"
              data-controller="clipboard">
            <div class="shrink-0 w-[60px] h-[60px] rounded overflow-hidden bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800">
              <%= image_tag public_url,
                    alt: blob.filename.to_s,
                    class: "w-full h-full object-cover",
                    loading: "lazy" %>
            </div>

            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate" title="<%= blob.filename %>">
                <%= blob.filename %>
              </p>
              <p class="font-mono text-[11px] text-zinc-500 dark:text-zinc-400 mt-0.5 tabular-nums">
                <%= number_to_human_size(blob.byte_size) %>
              </p>
              <div class="mt-2 flex items-center gap-2">
                <code class="flex-1 min-w-0 truncate text-[12px] font-mono px-2 py-1 rounded bg-zinc-50 dark:bg-zinc-950/60 border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300"
                      data-clipboard-target="source"><%= public_url %></code>
                <button type="button"
                        data-clipboard-target="button"
                        data-action="click->clipboard#copy"
                        class="shrink-0 button-secondary button-smaller">
                  Copy URL
                </button>
              </div>
            </div>

            <%# link_to + turbo_method:delete (not button_to) so the delete
                control doesn't render a nested <form> inside the surrounding
                form_with. See git blame for the full story. %>
            <div class="shrink-0">
              <%= link_to "Delete",
                    destroy_asset_path.call(attachment),
                    data: { turbo_method: :delete, turbo_confirm: "Delete this image? This cannot be undone." },
                    class: "button-secondary button-smaller button-danger" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% elsif resource.persisted? %>
      <p class="text-[13px] text-zinc-500 dark:text-zinc-400">
        <span class="font-mono text-[11px] uppercase tracking-widest mr-1">Empty</span>
        No images uploaded yet. Drop or paste one into the editor above.
      </p>
    <% else %>
      <p class="text-[13px] text-zinc-500 dark:text-zinc-400">
        <span class="font-mono text-[11px] uppercase tracking-widest mr-1">Pending save</span>
        Save this <%= resource_name.humanize.downcase %> first, then add images from inside the editor.
      </p>
    <% end %>
  </div>
</details>
