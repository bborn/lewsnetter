<% expand ||= false %>

<% unless hide_team_resource_menus? %>
  <%# Top-level: Dashboard + Campaigns (primary action) flat. Audience and
      Sending grouped in dropdowns. Team admin lives in the existing Team
      subsection at the bottom. %>
  <%= render 'account/shared/menu/section' do %>
    <%= render 'account/teams/menu_item' %>
    <%= render 'account/campaigns/menu_item' %>
    <%= render 'account/scaffolding/absolutely_abstract/creative_concepts/menu_item' unless scaffolding_things_disabled? %>
    <% # added by super scaffolding. %>
  <% end %>

  <%= render 'account/shared/menu/subsection', title: t('menus.main.labels.audience', default: 'Audience'), expand: expand do %>
    <%= render 'account/subscribers/menu_item' %>
    <%= render 'account/segments/menu_item' %>
  <% end %>

  <%= render 'account/shared/menu/subsection', title: t('menus.main.labels.sending', default: 'Sending'), expand: expand do %>
    <%= render 'account/email_templates/menu_item' %>
    <%= render 'account/sender_addresses/menu_item' %>
  <% end %>

  <% @last_menu_orientation = @menu_orientation %>
  <% @menu_orientation = :side %>
  <% integrations = capture do %>
    <%= render 'account/integrations/stripe_installations/menu_item' if stripe_enabled? %>
    <%# 🚅 super scaffolding will insert new oauth providers above this line. %>
  <% end %>
  <% @menu_orientation = @last_menu_orientation %>

  <%# We don't want to show this menu section if the menu items only rendered annotations. %>
  <% if integrations.gsub(/<!--(.*)-->/, "").present? %>
    <%= render 'account/shared/menu/subsection', title: t('menus.main.labels.integrations'), expand: expand do %>
      <%= integrations %>
    <% end %>
  <% end %>

  <%# Developers: lewsnetter-rails sync setup + raw OAuth applications +
      outgoing webhook endpoints. The "Sync setup" page is the
      friendly path; the others are for advanced users. %>
  <%= render 'account/shared/menu/subsection', title: t('menus.main.labels.developers', default: 'Developers'), expand: expand do %>
    <%= render 'account/developers/menu_item' %>
    <%= render 'account/platform/applications/menu_item' %>
    <%= render 'account/webhooks/outgoing/endpoints/menu_item' if webhooks_enabled? %>
  <% end %>

  <%# Team Settings + Members live in the avatar dropdown — see
      account/shared/menu/_user_items.html.erb. Keeps the top nav focused
      on the primary work (Dashboard / Campaigns / Audience / Sending). %>
<% end %>

<% if expand %>
  <%= render 'account/shared/menu/subsection', title: t('menus.main.labels.your_account'), expand: expand do %>
    <%= render "account/shared/menu/user_items" %>
  <% end %>
<% end %>
