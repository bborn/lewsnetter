<%# A single chat message bubble. Rendered both at page load (server) and %>
<%# in real-time via the ChatChannel (broadcasts the rendered HTML). %>
<%# locals: { message: Message } %>

<% case message.role.to_s %>
<% when "user" %>
  <div class="flex justify-end">
    <div class="bg-zinc-100 text-zinc-900 rounded-lg px-4 py-2 max-w-[85%] text-sm">
      <%= simple_format(message.content) %>
    </div>
  </div>
<% when "assistant" %>
  <%# Skip empty assistant messages — ruby_llm creates an empty placeholder %>
  <%# row before a tool call resolves; the tool_calls below render the action. %>
  <% if message.content.present? %>
    <div class="flex justify-start">
      <div class="bg-white border border-zinc-200 text-zinc-900 rounded-lg px-4 py-2 max-w-[85%] text-sm">
        <%= simple_format(message.content) %>
      </div>
    </div>
  <% end %>
<% when "system" %>
  <%# system messages are instructions; don't render in the UI %>
<% when "tool" %>
  <div class="text-xs text-zinc-500 font-mono px-2">
    ← <%= message.content.to_s.truncate(180) %>
  </div>
<% end %>

<% if message.respond_to?(:tool_calls) && message.tool_calls.any? %>
  <% message.tool_calls.each do |tc| %>
    <div class="text-xs text-zinc-500 font-mono px-2">
      → <%= tc.name %>(<%= tc.arguments&.to_json %>)
    </div>
  <% end %>
<% end %>
