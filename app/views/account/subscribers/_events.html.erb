<%# Renders the most recent 20 events for a subscriber. Each row shows
    timestamp, name, and a peek at the JSON properties. %>
<%= render 'account/shared/box', divider: true do |box| %>
  <% box.title "Recent events" %>
  <% box.description do %>
    The 20 most recent behavioral events recorded for this subscriber.
    Used by Segments to target campaign sends.
  <% end %>

  <% box.table do %>
    <% if events.any? %>
      <table class="table">
        <thead>
          <tr>
            <th>Occurred</th>
            <th>Name</th>
            <th>Properties</th>
            <th class="text-right"></th>
          </tr>
        </thead>
        <tbody>
          <% events.each do |event| %>
            <tr>
              <td class="whitespace-nowrap"><%= l(event.occurred_at, format: :short) if event.occurred_at %></td>
              <td class="font-mono"><%= event.name %></td>
              <td>
                <% if event.properties.present? %>
                  <code class="text-xs text-base-600 dark:text-base-300">
                    <%= event.properties.to_json.truncate(120) %>
                  </code>
                <% else %>
                  <span class="text-base-400">—</span>
                <% end %>
              </td>
              <td class="text-right">
                <%= link_to "View", [:account, event], class: "button-secondary button-smaller" if can?(:read, event) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="text-center px-6 py-10">
        <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">No events yet</div>
        <p class="text-zinc-600 dark:text-zinc-400 max-w-md mx-auto">
          Behavioral events (opens, clicks, custom signals) appear here.
          Segments target campaigns based on this activity.
        </p>
      </div>
    <% end %>
  <% end %>

  <% box.actions do %>
    <% if can?(:create, Event.new(subscriber: subscriber, team: subscriber.team)) %>
      <%= link_to "Add event", new_account_subscriber_event_path(subscriber), class: first_button_primary %>
    <% end %>
    <% if events.any? && can?(:read, Event) %>
      <%= link_to "View all", [:account, subscriber, :events], class: "button-secondary" %>
    <% end %>
  <% end %>
<% end %>
