<% subscribers = subscribers.accessible_by(current_ability) %>
<% team = @team %>
<% context ||= team %>
<% collection ||= :subscribers %>
<% hide_actions ||= false %>
<% hide_back ||= false %>

<% pagy ||= nil %>
<% pagy, subscribers = pagy(subscribers, page_param: :subscribers_page) unless pagy %>

<%= action_model_select_controller do %>
  <% cable_ready_updates_for context, collection do %>
    <%= render 'account/shared/box', pagy: pagy do |box| %>
      <% box.title t(".contexts.#{context.class.name.underscore}.header") %>
      <% box.description do %>
        <% if subscribers.any? %>
          <%= t(".contexts.#{context.class.name.underscore}.description") %>
        <% end %>
        <%= render "shared/limits/index", model: subscribers.model %>
      <% end %>

      <% box.table do %>
        <% if subscribers.any? %>
          <table class="table">
            <thead>
              <tr>
                <%= render "shared/tables/select_all" %>
                <th><%= t('.fields.external_id.heading') %></th>
                <th><%= t('.fields.email.heading') %></th>
                <th><%= t('.fields.name.heading') %></th>
                <th  class="text-center"><%= t('.fields.subscribed.heading') %></th>
                <%# 🚅 super scaffolding will insert new field headers above this line. %>
                <th><%= t('.fields.created_at.heading') %></th>
                <th class="text-right"></th>
              </tr>
            </thead>
            <tbody>
              <%= render partial: 'account/subscribers/subscriber', collection: subscribers %>
            </tbody>
          </table>
        <% elsif context == team && can?(:create, Subscriber.new(team: team)) %>
          <div class="text-center py-12 px-6">
            <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">No subscribers yet</div>
            <h3 class="text-[18px] font-semibold text-zinc-900 dark:text-zinc-100 mb-2">Add your audience</h3>
            <p class="text-zinc-500 dark:text-zinc-400 max-w-md mx-auto mb-6">
              Add one at a time, or import from CSV. There's one audience per team — target subsets with Segments.
            </p>
            <div class="flex flex-wrap gap-3 justify-center">
              <%= link_to "Add subscriber", [:new, :account, team, :subscriber], class: "button" %>
              <%= link_to "Import from CSV", new_account_team_subscribers_import_path(team), class: "button-secondary" %>
            </div>
          </div>
        <% end %>
      <% end %>

      <% box.actions do %>
        <% unless hide_actions %>
          <%# B11: when the empty-state card is showing its own "Add
              subscriber" + "Import from CSV" buttons, suppress this second
              copy so they don't render twice on the same screen. %>
          <% if context == team && subscribers.any? %>
            <% if can? :create, Subscriber.new(team: team) %>
              <%= link_to t('.buttons.new'), [:new, :account, team, :subscriber], class: "#{first_button_primary(:subscriber)} new" %>
            <% end %>
            <%= render 'account/subscribers/imports/dashboard_card', team: team %>
          <% end %>

          <%# 🚅 super scaffolding will insert new targets one parent action model buttons above this line. %>
          <%# 🚅 super scaffolding will insert new bulk action model buttons above this line. %>
          <%= render "shared/bulk_action_select" if subscribers.any? %>

          <% unless hide_back %>
            <%= link_to t('global.buttons.back'), [:account, context], class: "#{first_button_primary(:subscriber)} back" %>
          <% end %>
        <% end %>
      <% end %>

      <% box.raw_footer do %>
        <%# 🚅 super scaffolding will insert new action model index views above this line. %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
