<%
  page_title = @subscriber.email.presence || @subscriber.name.presence || @subscriber.external_id.presence || "Subscriber ##{@subscriber.id}"
  page_subtitle = @subscriber.name.presence if @subscriber.email.present?
  custom_attrs = (@subscriber.custom_attributes || {}).reject { |_, v| v.blank? }
  recent_events = @subscriber.events.order(occurred_at: :desc).limit(20)
%>
<%= render 'account/shared/page' do |page| %>
  <% page.title page_title %>
  <% page.body do %>
    <%= cable_ready_updates_for @subscriber do %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title t('.header') %>
        <% box.description do %>
          <% if page_subtitle %><span class="text-base-500"><%= page_subtitle %></span><br><% end %>
          <%= t('.description') %>
          <%= t('.manage_description') if can? :manage, @subscriber %>
        <% end %>

        <% box.body do %>
          <% with_attribute_settings object: @subscriber, strategy: :label do %>
            <%= render 'shared/attributes/text', attribute: :external_id %>
            <%= render 'shared/attributes/email', attribute: :email %>
            <%= render 'shared/attributes/text', attribute: :name %>
            <%= render 'shared/attributes/option', attribute: :subscribed %>
            <%# 🚅 super scaffolding will insert new fields above this line. %>
          <% end %>
        <% end %>

        <% box.actions do %>
          <%= link_to t('.buttons.edit'), [:edit, :account, @subscriber], class: first_button_primary if can? :edit, @subscriber %>
          <%# 🚅 super scaffolding will insert new action model buttons above this line. %>
          <%= button_to t('.buttons.destroy'), [:account, @subscriber], method: :delete, class: first_button_primary, data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@subscriber)) } if can? :destroy, @subscriber %>
          <%= link_to t('global.buttons.back'), [:account, @team, :subscribers], class: first_button_primary %>
        <% end %>

        <% box.raw_footer do %>
          <%# 🚅 super scaffolding will insert new action model index views above this line. %>
        <% end %>
      <% end %>
    <% end %>

    <%= render 'account/subscribers/custom_attributes', subscriber: @subscriber, custom_attrs: custom_attrs %>

    <%= render 'account/subscribers/events', subscriber: @subscriber, events: recent_events %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>
