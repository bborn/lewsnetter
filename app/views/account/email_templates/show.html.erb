<%= render 'account/shared/page' do |page| %>
  <% page.title t('.section') %>
  <% page.body do %>
    <%= cable_ready_updates_for @email_template do %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title t('.header') %>
        <% box.description do %>
          <%= t('.description') %>
          <%= t('.manage_description') if can? :manage, @email_template %>
        <% end %>

        <% box.body do %>
          <% with_attribute_settings object: @email_template, strategy: :label do %>
            <%= render 'shared/attributes/text', attribute: :name %>
            <%# 🚅 super scaffolding will insert new fields above this line. %>
          <% end %>

          <%# Rendered preview. Compiles the template MJML through the same
              CampaignRenderer used for real sends, with placeholder body
              content + a fake subscriber. Authors see the template chrome
              wrapping a representative body without committing to a campaign. %>
          <div class="mt-6">
            <label class="block text-sm font-medium mb-2">Preview</label>
            <div class="border rounded-md overflow-hidden bg-white dark:bg-base-900">
              <iframe src="<%= preview_frame_account_email_template_path(@email_template) %>"
                      class="w-full"
                      style="height: 640px; border: 0;"
                      sandbox="allow-same-origin"
                      title="Template preview"></iframe>
            </div>
            <p class="text-xs text-gray-500 mt-1">
              Shows the template wrapping a placeholder body. Real campaigns
              fill the <code class="font-mono">{{body}}</code> placeholder with
              their own markdown content.
            </p>
          </div>

          <%# Raw MJML disclosure for the curious — collapsed by default so
              the show page doesn't dump a wall of text. %>
          <details class="mt-4 rounded-md border border-base-200 dark:border-base-700 bg-base-50 dark:bg-base-800/40 px-3 py-2">
            <summary class="cursor-pointer select-none text-sm font-medium text-base-700 dark:text-base-300">
              Show MJML source
            </summary>
            <pre class="mt-3 text-xs font-mono whitespace-pre-wrap text-base-700 dark:text-base-300 overflow-auto max-h-96"><%= @email_template.mjml_body %></pre>
          </details>
        <% end %>

        <% box.actions do %>
          <%= link_to t('.buttons.edit'), [:edit, :account, @email_template], class: first_button_primary if can? :edit, @email_template %>
          <%# 🚅 super scaffolding will insert new action model buttons above this line. %>
          <%= button_to t('.buttons.destroy'), [:account, @email_template], method: :delete, class: first_button_primary, data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@email_template)) } if can? :destroy, @email_template %>
          <%= link_to t('global.buttons.back'), [:account, @team, :email_templates], class: first_button_primary %>
        <% end %>

        <% box.raw_footer do %>
          <%# 🚅 super scaffolding will insert new action model index views above this line. %>
        <% end %>
      <% end %>
    <% end %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>
