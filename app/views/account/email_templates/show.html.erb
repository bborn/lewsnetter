<%
  short_id = @email_template.respond_to?(:obfuscated_id) ? @email_template.obfuscated_id : @email_template.id
  campaigns_using = @email_template.respond_to?(:campaigns) ? @email_template.campaigns.count : 0
  byte_size = @email_template.mjml_body.to_s.bytesize
%>
<%= render 'account/shared/page' do |page| %>
  <%# Editorial header below serves as the title; skip the default H1. %>
  <% page.title nil %>

  <% page.body do %>
    <%= cable_ready_updates_for @email_template do %>

      <%# ============================================================
          Editorial header — eyebrow + name + actions.
          ============================================================ %>
      <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl mb-6 p-10">
        <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-3 flex items-center gap-2">
          <span>Template · <%= short_id %></span>
          <span class="text-zinc-300 dark:text-zinc-700">·</span>
          <span><%= campaigns_using %> campaign<%= "s" unless campaigns_using == 1 %> using this</span>
        </div>
        <h1 class="text-zinc-900 dark:text-zinc-50 font-semibold text-[32px] leading-tight tracking-tight mb-1">
          <%= @email_template.name.presence || "Untitled template" %>
        </h1>
        <p class="font-mono text-[13px] text-zinc-500 dark:text-zinc-400 mb-7">
          Reusable layout. Real campaigns fill <span class="text-zinc-700 dark:text-zinc-300">{{body}}</span>.
        </p>
        <div class="flex items-center gap-2 flex-wrap">
          <% if can? :edit, @email_template %>
            <%= link_to "Edit template →", [:edit, :account, @email_template], class: "button" %>
          <% end %>
          <% if can? :destroy, @email_template %>
            <%= button_to "Delete", [:account, @email_template], method: :delete,
                  class: "button-secondary button-danger",
                  data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@email_template)) } %>
          <% end %>
          <%= link_to "Back to templates", [:account, @team, :email_templates], class: "button-light" %>
        </div>
      </div>

      <%# ============================================================
          Rendered preview — frame it like an artifact.
          ============================================================ %>
      <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden mb-6">
        <div class="px-6 py-4 flex items-baseline justify-between border-b border-zinc-200 dark:border-zinc-800">
          <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Rendered preview</div>
          <div class="font-mono text-[11px] tabular-nums text-zinc-400 dark:text-zinc-500">
            <%= number_with_delimiter(byte_size) %> bytes
          </div>
        </div>
        <iframe src="<%= preview_frame_account_email_template_path(@email_template) %>"
                class="w-full bg-white"
                style="height: 640px; border: 0;"
                sandbox="allow-same-origin"
                title="Template preview"></iframe>
      </div>

      <%# ============================================================
          MJML source disclosure — collapsed; the chrome of the
          page is the rendered preview, source is for engineers.
          ============================================================ %>
      <details class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg mb-6 group">
        <summary class="px-6 py-4 cursor-pointer select-none flex items-center justify-between hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors">
          <span class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400">MJML source</span>
          <span class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 group-open:hidden">Show ▾</span>
          <span class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 hidden group-open:inline">Hide ▴</span>
        </summary>
        <pre class="text-[12px] font-mono whitespace-pre-wrap text-zinc-700 dark:text-zinc-300 bg-zinc-50 dark:bg-zinc-950 px-6 py-4 overflow-auto max-h-96 border-t border-zinc-200 dark:border-zinc-800"><%= @email_template.mjml_body %></pre>
      </details>

      <%# 🚅 super scaffolding will insert new action model index views above this line. %>
    <% end %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>
