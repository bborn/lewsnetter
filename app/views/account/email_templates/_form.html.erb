<% cancel_path ||= email_template.persisted? ? [:account, email_template] : [:account, @team, :email_templates] %>

<%# multipart: true so the form encodes file uploads correctly — required
    by the Assets section (has_many_attached :assets). Without this the
    file field silently submits filenames as plain strings. %>
<%= form_with model: email_template, url: (email_template.persisted? ? [:account, email_template] : [:account, @team, :email_templates]), html: { multipart: true }, class: 'form' do |form| %>
  <%= render "shared/limits/form", form: form, cancel_path: cancel_path do %>
    <%= render 'account/shared/forms/errors', form: form %>

    <% with_field_settings form: form do %>
      <%= render 'shared/fields/text_field', method: :name, options: {autofocus: true} %>
      <%# CodeMirror 6 wraps the textarea on connect — preserves all the
          BulletTrain label/help/error rendering of the field partial while
          giving authors a real code editor (line numbers, XML highlighting,
          bracket matching, search). Falls back to a plain textarea if JS
          is disabled. %>
      <%= render 'shared/fields/text_area', method: :mjml_body,
                 options: {rows: 20, class: "font-mono text-xs", placeholder: "<mjml>\n  <mj-body>\n    <mj-section>\n      <mj-column>\n        <mj-text>Hello {{first_name}}!</mj-text>\n        {{body}}\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>",
                   data: {controller: "code-editor", code_editor_language_value: "xml", code_editor_min_height_value: "520px"}} %>

      <div class="-mt-2 space-y-2 text-sm text-zinc-600 dark:text-zinc-400">
        <details class="rounded-md border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950/40 group">
          <summary class="cursor-pointer select-none px-4 py-3 flex items-center justify-between hover:bg-zinc-100/60 dark:hover:bg-zinc-800/40 transition-colors">
            <span class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400">Available variables</span>
            <span class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 group-open:hidden">Show ▾</span>
            <span class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 hidden group-open:inline">Hide ▴</span>
          </summary>
          <ul class="px-4 pt-3 pb-4 space-y-2 leading-relaxed border-t border-zinc-200 dark:border-zinc-800 text-[13px]">
            <li><code class="font-mono text-zinc-900 dark:text-zinc-100">{{first_name}}</code> — the subscriber's first name (best-effort split on space).</li>
            <li><code class="font-mono text-zinc-900 dark:text-zinc-100">{{name}}</code> — the subscriber's full name as stored.</li>
            <li><code class="font-mono text-zinc-900 dark:text-zinc-100">{{email}}</code> — the subscriber's email address.</li>
            <li><code class="font-mono text-zinc-900 dark:text-zinc-100">{{external_id}}</code> — the subscriber's <code>external_id</code> (if set).</li>
            <li><code class="font-mono text-zinc-900 dark:text-zinc-100">{{unsubscribe_url}}</code> — required by mailkick; the team-specific unsubscribe URL for this subscriber.</li>
            <li><code class="font-mono text-zinc-900 dark:text-zinc-100">{{body}}</code> — for templates: the campaign's markdown body, compiled to MJML and injected here.</li>
            <li>
              Any key from a subscriber's <code class="font-mono text-zinc-900 dark:text-zinc-100">custom_attributes</code> is also available —
              e.g. <code class="font-mono text-zinc-900 dark:text-zinc-100">{{plan}}</code>, <code class="font-mono text-zinc-900 dark:text-zinc-100">{{signup_source}}</code>.
            </li>
          </ul>
        </details>
        <p>
          <a href="https://documentation.mjml.io/" target="_blank" rel="noopener" class="text-zinc-700 dark:text-zinc-300 hover:text-primary-600 underline-offset-2 hover:underline">
            MJML reference docs ↗
          </a>
        </p>
      </div>
      <%# 🚅 super scaffolding will insert new fields above this line. %>
    <% end %>

    <%= render "account/shared/assets/section", form: form, resource: email_template %>

    <div class="buttons">
      <%= form.submit (form.object.persisted? ? t('.buttons.update') : t('.buttons.create')), class: "button" %>
      <%= link_to t('global.buttons.cancel'), cancel_path, class: "button-secondary" %>
    </div>
  <% end %>
<% end %>
