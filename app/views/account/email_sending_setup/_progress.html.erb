<%
  # Loops-style 4-segment progress bar. Each step is a flex-1 bar that
  # fills orange when active or completed, stays zinc-200 otherwise.
  # Compact, no labels per segment — the card header carries the label.
  steps = [
    {id: :credentials,   label: "Credentials"},
    {id: :domain,        label: "Domain"},
    {id: :verify_domain, label: "Verify DNS"},
    {id: :test,          label: "Send test"}
  ]
  current_index = steps.index { |s| s[:id] == step } || (step == :done ? steps.length : 0)
  current_label = steps[current_index]&.dig(:label) || "Done"
%>
<div class="space-y-2">
  <div class="flex items-center gap-1.5">
    <% steps.each_with_index do |s, i| %>
      <%
        fill_state =
          if i < current_index then "bg-orange-600 dark:bg-orange-500"
          elsif i == current_index then "bg-orange-600 dark:bg-orange-500"
          else "bg-zinc-200 dark:bg-zinc-800"
          end
      %>
      <div class="flex-1 h-1 rounded-full <%= fill_state %>"></div>
    <% end %>
  </div>
  <div class="flex items-center justify-between text-[10px] font-mono uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
    <span>Step <%= [current_index + 1, steps.length].min %> of <%= steps.length %></span>
    <span><%= current_label %></span>
  </div>
</div>
