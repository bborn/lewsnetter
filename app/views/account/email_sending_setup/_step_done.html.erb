<div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg p-8 text-center">
  <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-emerald-100 dark:bg-emerald-950 text-emerald-700 dark:text-emerald-300 mb-4">
    <span class="text-2xl">✓</span>
  </div>
  <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50 mb-2">You're set up to send.</h2>
  <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6 max-w-md mx-auto">
    Credentials verified, sender verified, test sent. You can compose your first campaign whenever you're ready.
  </p>
  <div class="flex items-center justify-center gap-3 flex-wrap">
    <%= link_to "Start a campaign", [:new, :account, team, :campaign], class: "button" %>
    <%= link_to "Manage email sending", [:account, team, :email_sending], class: "button-secondary" %>
  </div>
</div>
