<%# Step 2 — Sending domain + company address. Mirrors Loops's domain
    input pattern: clear label, helper info box recommending a subdomain,
    and an optional postal-address field for CAN-SPAM compliance. Single
    dark CTA, no choice fork (domain is the only primary path). %>
<%
  ses_domain ||= local_assigns[:ses_domain] || team.build_ses_domain
  ses_configuration ||= local_assigns[:ses_configuration]
%>
<div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden">
  <div class="px-6 pt-6 pb-4">
    <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-50">Sending domain</h2>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">
      We'll set up DKIM on your domain so your emails authenticate cleanly with Gmail, Outlook, and Apple Mail.
    </p>
  </div>

  <%= form_with url: account_team_setup_domain_email_sending_path(team), method: :post, class: 'form' do |form| %>
    <div class="px-6 py-5 space-y-5 border-t border-zinc-100 dark:border-zinc-800">

      <div>
        <label for="team_ses_domain_domain" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">
          Sending domain
        </label>
        <input type="text"
               id="team_ses_domain_domain"
               name="team_ses_domain[domain]"
               value="<%= ses_domain.domain %>"
               placeholder="hey.example.com"
               autocomplete="off"
               required
               class="w-full px-3 py-2 font-mono text-sm border border-zinc-300 dark:border-zinc-700 rounded-md bg-white dark:bg-zinc-950 focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500" />
        <div class="mt-3 rounded-md bg-zinc-50 dark:bg-zinc-950/60 border border-zinc-200 dark:border-zinc-800 px-3 py-2.5">
          <p class="text-xs text-zinc-600 dark:text-zinc-300 leading-relaxed">
            We recommend a subdomain like <code class="font-mono text-zinc-800 dark:text-zinc-100">hey.example.com</code> for most companies — sending from your root domain works too, but a subdomain keeps marketing mail separate from your transactional mail's reputation.
          </p>
        </div>
      </div>

      <div>
        <label for="team_ses_configuration_physical_postal_address" class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">
          Company postal address <span class="font-normal text-zinc-400">(optional)</span>
        </label>
        <textarea id="team_ses_configuration_physical_postal_address"
                  name="team_ses_configuration[physical_postal_address]"
                  rows="2"
                  placeholder="123 Sand Hill Road, Menlo Park, CA 94025"
                  class="w-full px-3 py-2 text-sm border border-zinc-300 dark:border-zinc-700 rounded-md bg-white dark:bg-zinc-950 focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500"><%= ses_configuration.physical_postal_address %></textarea>
        <p class="mt-1.5 text-[11px] text-zinc-500 dark:text-zinc-400">
          Required in your email footer (US CAN-SPAM). You can fill this in later.
        </p>
      </div>

    </div>
    <div class="px-6 pb-6">
      <%= form.submit "Continue",
            class: "w-full inline-flex items-center justify-center px-4 py-2.5 rounded-md bg-zinc-900 dark:bg-zinc-50 text-white dark:text-zinc-900 text-sm font-medium hover:bg-zinc-800 dark:hover:bg-zinc-200 cursor-pointer" %>
    </div>
  <% end %>
</div>
