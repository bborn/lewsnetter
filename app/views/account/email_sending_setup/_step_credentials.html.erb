<%# Step 1 — AWS credentials. Loops-style card: centered narrow column,
    single dark CTA, body copy explaining what we're collecting. Per
    DESIGN.md we keep our orange CTA + zinc neutrals. %>
<div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden">
  <div class="px-6 pt-6 pb-4">
    <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-50">Connect Amazon SES</h2>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">
      Lewsnetter sends through your own AWS account — you bring the keys, you own the reputation and the bill.
    </p>
  </div>

  <details class="border-t border-zinc-100 dark:border-zinc-800 group">
    <summary class="cursor-pointer px-6 py-3 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 list-none flex items-center justify-between">
      <span class="text-sm font-medium text-zinc-700 dark:text-zinc-200">How to get an Access Key ID + Secret</span>
      <span class="text-zinc-400 group-open:rotate-90 transition-transform">›</span>
    </summary>
    <div class="px-6 pb-5 text-sm text-zinc-600 dark:text-zinc-300 space-y-3">
      <ol class="list-decimal pl-5 space-y-2">
        <li>Open the <a href="https://console.aws.amazon.com/iam/home#/users" target="_blank" rel="noopener" class="text-orange-700 dark:text-orange-400 hover:underline">AWS IAM Users console</a> and create a new user (e.g. <code class="font-mono">lewsnetter-ses</code>) with <em>Programmatic access</em>.</li>
        <li>Attach this IAM policy (copy-paste):</li>
      </ol>
      <pre class="bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded p-3 text-[11px] font-mono text-zinc-700 dark:text-zinc-200 overflow-x-auto">{
  "Version": "2012-10-17",
  "Statement": [{
    "Effect": "Allow",
    "Action": [
      "ses:SendEmail", "ses:SendRawEmail", "ses:GetAccount",
      "ses:ListEmailIdentities", "ses:CreateEmailIdentity", "ses:GetEmailIdentity",
      "ses:GetSendQuota"
    ],
    "Resource": "*"
  }]
}</pre>
      <ol class="list-decimal pl-5 space-y-2" start="3">
        <li>Create an Access Key for that user — save the Access Key ID + Secret somewhere safe.</li>
        <li>Pick the AWS region you want to send from. <code class="font-mono">us-east-1</code> is the default + cheapest egress for most folks.</li>
      </ol>
    </div>
  </details>

  <%= form_with model: ses_configuration,
                url: account_team_setup_email_sending_path(team),
                method: :patch, class: 'form', scope: :team_ses_configuration do |form| %>
    <div class="px-6 py-5 space-y-4 border-t border-zinc-100 dark:border-zinc-800">
      <div>
        <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">AWS Access Key ID</label>
        <%= form.text_field :encrypted_access_key_id,
              placeholder: ses_configuration.configured? ? "•••• #{ses_configuration.access_key_id_last_four} (leave blank to keep)" : "AKIA…",
              autocomplete: "off",
              class: "w-full px-3 py-2 border border-zinc-300 dark:border-zinc-700 rounded-md text-sm bg-white dark:bg-zinc-950 focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">AWS Secret Access Key</label>
        <%= form.password_field :encrypted_secret_access_key,
              placeholder: ses_configuration.configured? ? "•••• (leave blank to keep)" : "AWS secret key",
              autocomplete: "off",
              class: "w-full px-3 py-2 border border-zinc-300 dark:border-zinc-700 rounded-md text-sm bg-white dark:bg-zinc-950 focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">AWS Region</label>
        <%= form.text_field :region, placeholder: "us-east-1",
              class: "w-full px-3 py-2 border border-zinc-300 dark:border-zinc-700 rounded-md text-sm bg-white dark:bg-zinc-950 focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500" %>
      </div>
    </div>
    <div class="px-6 pb-6">
      <%= form.submit "Verify with AWS",
            class: "w-full inline-flex items-center justify-center px-4 py-2.5 rounded-md bg-zinc-900 dark:bg-zinc-50 text-white dark:text-zinc-900 text-sm font-medium hover:bg-zinc-800 dark:hover:bg-zinc-200 cursor-pointer" %>
    </div>
  <% end %>
</div>
