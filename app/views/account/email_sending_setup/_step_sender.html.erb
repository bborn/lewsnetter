<%
  # Fetch identities we already know about in SES so the user can one-click
  # import a pre-verified address instead of starting over.
  identities = (Ses::Verifier.new(team: team).call.identities rescue [])
  importable = identities.select { |i| i[:type] == "EMAIL_ADDRESS" && i[:verified] }
  already_imported = team.sender_addresses.pluck(:email)
  importable.reject! { |i| already_imported.include?(i[:identity]) }
%>
<div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg overflow-hidden">
  <div class="p-6 border-b border-zinc-100 dark:border-zinc-800">
    <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">Step 2 — Pick a sender</h2>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">
      Every campaign goes out from one of your verified senders. Pick an address AWS already knows, or add a new one (we'll trigger an AWS verification email).
    </p>
  </div>

  <% if importable.any? %>
    <div class="p-6 border-b border-zinc-100 dark:border-zinc-800">
      <div class="text-[10px] uppercase tracking-widest font-mono text-zinc-500 dark:text-zinc-400 mb-3">
        Already verified in your SES account
      </div>
      <ul class="divide-y divide-zinc-100 dark:divide-zinc-800">
        <% importable.each do |i| %>
          <li class="py-3 flex items-center justify-between gap-3">
            <span class="text-sm text-zinc-900 dark:text-zinc-100"><%= i[:identity] %></span>
            <%= button_to "Use this sender",
                  account_team_setup_sender_email_sending_path(team),
                  method: :post,
                  params: {identity: i[:identity]},
                  class: "button-secondary text-xs" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: account_team_setup_sender_email_sending_path(team), method: :post, class: 'form' do |form| %>
    <div class="p-6">
      <div class="text-[10px] uppercase tracking-widest font-mono text-zinc-500 dark:text-zinc-400 mb-3">
        Or add a new email
      </div>
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">Email address</label>
          <%= form.email_field :new_email, placeholder: "newsletter@yourdomain.com", required: true,
                class: "w-full p-2 border border-zinc-300 dark:border-zinc-700 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-200 mb-1">Display name <span class="font-normal text-zinc-400">(optional)</span></label>
          <%= form.text_field :name, placeholder: "Acme Newsletter",
                class: "w-full p-2 border border-zinc-300 dark:border-zinc-700 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500" %>
        </div>
      </div>
    </div>
    <div class="p-4 border-t border-zinc-100 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/50 flex items-center justify-end gap-3">
      <%= form.submit "Send verification email", class: "button" %>
    </div>
  <% end %>
</div>
