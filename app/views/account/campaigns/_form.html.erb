<% cancel_path ||= campaign.persisted? ? [:account, campaign] : [:account, @team, :campaigns] %>

<%# Tailwind classes shared by every plain <select> on this form. Keeping them
    on one local lets us reach feature parity with the rest of the field
    partials without depending on the upstream super_select / select2 chain,
    which doesn't surface a visible widget reliably on this page (the ejected
    _field.html.erb + content_for(:field) handoff loses the form.select markup
    on certain Turbo morph paths). Pragmatic > polished: native select with
    Tailwind chrome works everywhere and degrades cleanly. %>
<%
select_classes = "block w-full rounded-md shadow-sm font-light text-base md:text-sm border-base-300 dark:border-base-900 focus:ring-primary-500 focus:border-primary-500 dark:bg-base-800 dark:text-base-300"
%>

<%# ============================================================
    Editorial header — small mono eyebrow + the campaign subject as
    the visual H1 for this surface. The page-title H1 is sr-only on
    edit (see edit.html.erb). State pill keeps the user oriented when
    the campaign isn't a draft.
    ============================================================ %>
<header class="campaign-edit-header">
  <div class="campaign-edit-header__eyebrow">
    <span>Editing</span>
    <% if campaign.persisted? %>
      <span class="campaign-edit-header__id">· <%= campaign.to_param %></span>
      <%= status_pill(campaign.status) %>
    <% else %>
      <span class="campaign-edit-header__id">· New campaign</span>
    <% end %>
  </div>
  <h2 class="campaign-edit-header__title">
    <%= campaign.subject.presence || (campaign.persisted? ? "(no subject yet)" : "New campaign") %>
  </h2>
</header>

<%# State-aware lock banner — if the campaign is sent, editing should be
    locked. We still render the form below for completeness but show a
    persistent banner explaining the state. %>
<% if campaign.persisted? && campaign.sent? %>
  <aside class="campaign-edit-locked-banner">
    <strong>This campaign was sent<%= " on #{campaign.sent_at.strftime('%b %-d, %-l:%M %p')}" if campaign.sent_at %>.</strong>
    Edits won't affect already-delivered email. <%= link_to "View campaign", [:account, campaign], class: "campaign-edit-locked-banner__link" %>.
  </aside>
<% end %>

<%# ============================================================
    AI Drafter — its own card. Lives outside the main campaign form
    so we don't nest two forms in the DOM. The endpoint applies the
    LLM draft to the campaign and the page reloads to surface it.
    ============================================================ %>
<section class="campaign-edit-section campaign-edit-section--drafter">
  <header class="campaign-edit-section__header">
    <div class="campaign-edit-section__eyebrow">AI drafter</div>
    <h3 class="campaign-edit-section__title">Draft this campaign with AI</h3>
    <p class="campaign-edit-section__description">
      Give Claude five bullets and it returns a markdown body in your team's voice. You can still refine it below.
    </p>
  </header>
  <div class="campaign-edit-section__body campaign-edit-section__body--tight">
    <% if campaign.persisted? %>
      <div data-controller="ai-drafter"
           data-ai-drafter-url-value="<%= draft_account_campaign_path(campaign) %>"
           data-ai-drafter-csrf-value="<%= form_authenticity_token %>">
        <form data-action="submit->ai-drafter#submit" novalidate>
          <label class="campaign-edit-field-label" for="ai_drafter_brief">Brief</label>
          <textarea id="ai_drafter_brief"
                    data-ai-drafter-target="brief"
                    class="campaign-edit-drafter__textarea"
                    rows="5"
                    placeholder="- The headline change&#10;- Why it matters&#10;- One feature highlight&#10;- A user quote or stat&#10;- The call to action"></textarea>
          <div class="campaign-edit-drafter__footer">
            <p class="campaign-edit-drafter__hint">
              Uses team voice samples + segment context. Returns markdown body that overwrites the body below.
            </p>
            <div class="campaign-edit-drafter__actions">
              <span hidden
                    data-ai-drafter-target="spinner"
                    data-busy-label="Asking Claude…"
                    class="campaign-edit-drafter__spinner">Asking Claude…</span>
              <button type="submit"
                      class="button"
                      data-ai-drafter-target="submitButton">Draft with AI →</button>
            </div>
          </div>
          <p hidden
             data-ai-drafter-target="errorMessage"
             class="campaign-edit-drafter__error"></p>
        </form>
      </div>
    <% else %>
      <div>
        <label class="campaign-edit-field-label">Brief</label>
        <textarea class="campaign-edit-drafter__textarea"
                  rows="5"
                  disabled
                  placeholder="- The headline change&#10;- Why it matters&#10;- One feature highlight&#10;- A user quote or stat&#10;- The call to action"></textarea>
        <div class="campaign-edit-drafter__footer">
          <p class="campaign-edit-drafter__hint">
            Save the campaign once to unlock AI drafting.
          </p>
          <div class="campaign-edit-drafter__actions">
            <button type="button" class="button" disabled>Draft with AI →</button>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# multipart: true so file uploads in the Assets section below encode
    correctly — same rationale as the email_templates form. %>
<%= form_with model: campaign, url: (campaign.persisted? ? [:account, campaign] : [:account, @team, :campaigns]), html: { multipart: true }, class: 'form' do |form| %>
  <%= render "shared/limits/form", form: form, cancel_path: cancel_path do %>
    <%= render 'account/shared/forms/errors', form: form %>

    <% with_field_settings form: form do %>

      <%# Continuation of Section 1 (Content): subject, preheader, body,
          raw MJML disclosure, preview iframe. Visually a separate card so
          the section header stays with the AI draft above. %>
      <section class="campaign-edit-section">
        <header class="campaign-edit-section__header">
          <div class="campaign-edit-section__eyebrow">Section 1 · Content</div>
          <h3 class="campaign-edit-section__title">Content</h3>
          <p class="campaign-edit-section__description">Subject line, preheader, and the markdown body the template will wrap.</p>
        </header>
        <div class="campaign-edit-section__body">
          <%= render 'shared/fields/text_field', method: :subject, options: {autofocus: true} %>
          <%= render 'shared/fields/text_field', method: :preheader %>

          <%# Primary authoring path: markdown body. EasyMDE wraps the textarea
              with a toolbar + side-by-side preview. The Stimulus controller
              handles teardown on Turbo navigation (otherwise CodeMirror nodes
              leak). Underlying textarea name still campaign[body_markdown]
              so form submit picks up the latest value via EasyMDE's forceSync. %>
          <div class="campaign-edit-body-field">
            <div class="campaign-edit-body-field__header">
              <div>
                <label class="campaign-edit-field-label" for="campaign_body_markdown">Body</label>
                <p class="campaign-edit-field-hint">
                  Write in markdown. The template (selected below) wraps your content with header + footer chrome.
                </p>
              </div>

              <%# Variable picker — fetches the team's available {{vars}} on
                  first open and splices the selected token into the markdown
                  editor at the current cursor via the editor's public
                  insertAtCursor() method. %>
              <div class="relative shrink-0"
                   data-controller="variable-picker"
                   data-variable-picker-url-value="<%= account_team_variables_path(@team) %>"
                   data-variable-picker-editor-selector-value="#campaign_body_markdown">
                <button type="button"
                        class="button-secondary button-smaller"
                        data-variable-picker-target="button"
                        data-action="click->variable-picker#toggle">
                  Insert variable
                </button>
                <div data-variable-picker-target="panel"
                     class="absolute right-0 z-20 mt-1 w-72 bg-white dark:bg-zinc-900 rounded-md shadow-lg border border-zinc-200 dark:border-zinc-700 hidden">
                  <div class="p-2 border-b border-zinc-200 dark:border-zinc-700">
                    <input type="text"
                           placeholder="Filter variables…"
                           data-variable-picker-target="search"
                           data-action="input->variable-picker#filter"
                           class="block w-full rounded-md shadow-sm font-light dark:bg-zinc-900 dark:text-zinc-300 text-sm border-zinc-300 dark:border-zinc-700 focus:ring-primary-500 focus:border-primary-500" />
                  </div>
                  <ul data-variable-picker-target="list"
                      class="max-h-72 overflow-auto py-1"></ul>
                </div>
              </div>
            </div>
            <%= form.text_area :body_markdown,
                  id: "campaign_body_markdown",
                  class: "block w-full",
                  rows: 18,
                  data: {
                    controller: "markdown-editor",
                    "markdown-editor-target": "textarea"
                  } %>
          </div>

          <%# Legacy raw MJML body — hidden behind a disclosure for the small
              number of authors who want full MJML control. The warning lives
              inside the <summary> element so users see it BEFORE expanding the
              panel and pasting in MJML that would silently override their
              markdown body. %>
          <details class="campaign-edit-disclosure">
            <summary class="campaign-edit-disclosure__summary">
              <span class="campaign-edit-disclosure__eyebrow">Advanced</span>
              Show raw MJML <span class="campaign-edit-disclosure__caution">— overrides markdown body</span>
            </summary>
            <div class="campaign-edit-disclosure__body">
              <%= render 'shared/fields/text_area', method: :body_mjml,
                         options: {rows: 16, class: "font-mono text-xs", placeholder: "<mjml>\n  <mj-body>\n    <mj-section>\n      <mj-column>\n        <mj-text>Hello {{first_name}}!</mj-text>\n      </mj-column>\n    </mj-section>\n  </mj-body>\n</mjml>"} %>
            </div>
          </details>
        </div>
      </section>

      <%# ============================================================
          Live preview — framed as an artifact, separate card from
          the editor so authors can scroll the body without losing the
          preview's position.
          ============================================================ %>
      <% if campaign.persisted? %>
        <section class="campaign-edit-section campaign-edit-preview"
                 data-controller="campaign-preview"
                 data-campaign-preview-url-value="<%= preview_frame_account_campaign_path(campaign) %>"
                 data-campaign-preview-csrf-value="<%= form_authenticity_token %>"
                 data-action="markdown-editor:change@window->campaign-preview#schedule
                              ai-drafter:applied@window->campaign-preview#schedule
                              input->campaign-preview#scheduleFromInput
                              change->campaign-preview#scheduleFromInput">
          <header class="campaign-edit-section__header campaign-edit-preview__header">
            <div>
              <div class="campaign-edit-section__eyebrow">Live preview</div>
              <h3 class="campaign-edit-section__title">Rendered preview</h3>
              <p class="campaign-edit-section__description">Refreshes as you type. Use the template + sender + segment selected below.</p>
            </div>
            <div class="campaign-edit-preview__actions">
              <span data-campaign-preview-target="status" class="campaign-edit-preview__status"></span>
              <button type="button"
                      class="button-secondary button-smaller"
                      data-action="click->campaign-preview#refresh">
                Refresh
              </button>
            </div>
          </header>
          <div class="campaign-edit-preview__frame">
            <iframe id="campaign_preview_frame"
                    data-campaign-preview-target="iframe"
                    src="<%= preview_frame_account_campaign_path(campaign) %>"
                    class="campaign-edit-preview__iframe"
                    sandbox="allow-same-origin"
                    title="Campaign preview"></iframe>
          </div>
        </section>
      <% end %>

      <%# ============================================================
          Section 2 — Audience
          ============================================================ %>
      <section class="campaign-edit-section">
        <header class="campaign-edit-section__header">
          <div class="campaign-edit-section__eyebrow">Section 2 · Audience</div>
          <h3 class="campaign-edit-section__title">Audience</h3>
          <p class="campaign-edit-section__description">Who receives this campaign and which sender address sends it.</p>
        </header>
        <div class="campaign-edit-section__body campaign-edit-grid">

          <%# Plain <select> dropdowns. We deliberately bypass shared/fields/super_select
              here — that partial's content_for(:field) handoff into the ejected
              _field.html.erb doesn't surface a visible widget on this page
              (Bruno's 2026-05-12 annotation) AND it produces a duplicated
              "(optional)" suffix because the label branch in the ejected field
              partial runs even when super_select sets its own. A native select
              with Tailwind chrome is reliable, accessible, and matches the
              rest of the form visually. %>

          <div class="campaign-edit-field">
            <%= form.label :segment_id, "Segment", class: "campaign-edit-field-label" %>
            <%= form.select :segment_id,
                  @campaign.valid_segments.map { |segment| [segment.label_string, segment.id] },
                  {include_blank: t('campaigns.fields.segment_id.placeholder', default: '— Send to everyone subscribed —')},
                  class: "campaign-edit-select" %>
            <p class="campaign-edit-field-hint">
              Choose a saved segment or leave blank to send to all subscribed.
            </p>
          </div>

          <div class="campaign-edit-field">
            <%= form.label :sender_address_id, "Sender address", class: "campaign-edit-field-label" %>
            <%= form.select :sender_address_id,
                  @campaign.valid_sender_addresses.map { |sender| [sender.label_string, sender.id] },
                  {include_blank: "— Choose a verified sender —"},
                  class: "campaign-edit-select" %>
            <p class="campaign-edit-field-hint">
              Only verified sender addresses appear here. Add or verify in <em>Sender addresses</em>.
            </p>
          </div>
        </div>
      </section>

      <%# ============================================================
          Section 3 — Settings
          ============================================================ %>
      <section class="campaign-edit-section">
        <header class="campaign-edit-section__header">
          <div class="campaign-edit-section__eyebrow">Section 3 · Settings</div>
          <h3 class="campaign-edit-section__title">Settings</h3>
          <p class="campaign-edit-section__description">Optional schedule + which email template provides the layout chrome.</p>
        </header>
        <div class="campaign-edit-section__body campaign-edit-grid">

          <div class="campaign-edit-field">
            <%= form.label :email_template_id, "Template", class: "campaign-edit-field-label" %>
            <%= form.select :email_template_id,
                  @campaign.valid_email_templates.map { |template| [template.label_string, template.id] },
                  {include_blank: t('campaigns.fields.email_template_id.placeholder', default: 'None')},
                  class: "campaign-edit-select" %>
            <p class="campaign-edit-field-hint">
              The template wraps your body with header + footer chrome (logo, footer, unsubscribe).
            </p>
          </div>

          <%# B6: the gem's `shared/fields/date_and_time_field` partial relied on a
              flatpickr-wrapped Stimulus widget that wasn't rendering through the
              ejected `_field.html.erb` — the label appeared with no input below
              it. Use a plain native `<input type="datetime-local">` so users can
              actually pick a schedule. We pass the local-time iso8601 (no zone
              suffix) because that's what `datetime-local` accepts; the column
              type-casts it via Rails' default time zone. %>
          <div class="campaign-edit-field">
            <%= form.label :scheduled_for, "Scheduled for", class: "campaign-edit-field-label" %>
            <% scheduled_value = form.object.scheduled_for&.in_time_zone(Time.zone)&.strftime("%Y-%m-%dT%H:%M") %>
            <%= form.datetime_field :scheduled_for,
                  value: scheduled_value,
                  class: "campaign-edit-input" %>
            <p class="campaign-edit-field-hint">
              Leave blank to send immediately when you hit Send. Times are in
              <span class="campaign-edit-field-hint__mono"><%= Time.zone.name %></span>.
            </p>
          </div>
          <%# 🚅 super scaffolding will insert new fields above this line. %>
        </div>
      </section>

      <%# ============================================================
          Section 4 — Assets (uploads). The shared partial defines its
          own card chrome (mb-8 p-4 border rounded-md) — we don't touch
          it (it's shared with EmailTemplate edit). Wrap it in a class
          that re-skins it inline to match the .campaign-edit-section
          look without modifying the partial.
          ============================================================ %>
      <div class="campaign-edit-assets-wrap">
        <%= render "account/shared/assets/section", form: form, resource: campaign %>
      </div>
    <% end %>

    <%# Sticky action bar — primary CTA + cancel pinned to bottom of viewport so
        the user doesn't have to scroll back up after editing a long body. %>
    <div class="campaign-edit-actions">
      <div class="campaign-edit-actions__inner">
        <div class="campaign-edit-actions__hint">
          <% if campaign.persisted? %>
            Changes save on update. To send the campaign, go to <%= link_to "campaign overview", [:account, campaign], class: "campaign-edit-actions__link" %>.
          <% else %>
            Save first, then add audience + sender on the next screen.
          <% end %>
        </div>
        <div class="campaign-edit-actions__buttons">
          <%= link_to t('global.buttons.cancel'), cancel_path, class: "button-secondary" %>
          <%= form.submit (form.object.persisted? ? t('.buttons.update') : t('.buttons.create')), class: "button" %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
