<%# Renders inside #postmortem turbo-frame.
    Locals: campaign (Campaign), markdown (String). %>
<%= turbo_frame_tag "postmortem" do %>
  <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg p-6 my-6">
    <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-2">AI post-send analysis</div>
    <div class="mb-4">
      <%= open_in_agent_link(
        "Analyze the recent send: campaign id #{campaign.id}, subject \"#{campaign.subject}\". Pull stats with campaigns_postmortem, then suggest 3 actions.",
        label: "→ OPEN IN AGENT FOR DEEPER ANALYSIS"
      ) %>
    </div>
    <div class="prose dark:prose-invert max-w-none text-[15px] leading-relaxed">
      <%# Render the markdown verbatim if a renderer isn't available;
          BulletTrain doesn't ship a default markdown helper. Convert the
          simple subset (## headers + paragraphs) inline. %>
      <%= raw markdown.to_s.split(/\n\n+/).map { |para|
        if (m = para.match(/\A##\s+(.+)\z/))
          "<h4 class=\"font-semibold text-zinc-900 dark:text-zinc-100 mt-5 mb-2 text-base\">#{ERB::Util.html_escape(m[1])}</h4>"
        elsif para.start_with?("*") && para.end_with?("*") && !para.include?("\n")
          "<p class=\"font-mono text-xs text-zinc-500 dark:text-zinc-400\">#{ERB::Util.html_escape(para.gsub(/\A\*|\*\z/, ""))}</p>"
        else
          # Inline bold (**...**) and italics (*...*).
          escaped = ERB::Util.html_escape(para)
          escaped = escaped.gsub(/\*\*(.+?)\*\*/, "<strong>\\1</strong>")
          escaped = escaped.gsub(/(?<!\*)\*([^*]+?)\*(?!\*)/, "<em>\\1</em>")
          "<p class=\"mb-3 text-zinc-700 dark:text-zinc-300\">#{escaped}</p>"
        end
      }.join("\n") %>
    </div>
  </div>
<% end %>
