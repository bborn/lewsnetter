<% campaigns = campaigns.accessible_by(current_ability) %>
<% team = @team %>
<% context ||= team %>
<% collection ||= :campaigns %>
<% hide_actions ||= false %>
<% hide_back ||= false %>

<% pagy ||= nil %>
<% pagy, campaigns = pagy(campaigns, page_param: :campaigns_page) unless pagy %>

<%= action_model_select_controller do %>
  <% cable_ready_updates_for context, collection do %>
    <%= render 'account/shared/box', pagy: pagy do |box| %>
      <% box.title t(".contexts.#{context.class.name.underscore}.header") %>
      <% box.description do %>
        <%= t(".contexts.#{context.class.name.underscore}.description#{"_empty" unless campaigns.any?}") %>
        <%= render "shared/limits/index", model: campaigns.model %>
      <% end %>

      <% box.table do %>
        <% if campaigns.any? %>
          <table class="table">
            <thead>
              <tr>
                <%= render "shared/tables/select_all" %>
                <th><%= t('.fields.subject.heading') %></th>
                <th>Status</th>
                <th>Recipients</th>
                <th>Date</th>
                <%# 🚅 super scaffolding will insert new field headers above this line. %>
                <th class="text-right"></th>
              </tr>
            </thead>
            <tbody>
              <%= render partial: 'account/campaigns/campaign', collection: campaigns %>
            </tbody>
          </table>
        <% elsif context == team && can?(:create, Campaign.new(team: team)) %>
          <div class="text-center py-12 px-6">
            <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">No campaigns yet</div>
            <h3 class="text-[18px] font-semibold text-zinc-900 dark:text-zinc-100 mb-2">Draft your first newsletter</h3>
            <p class="text-zinc-500 dark:text-zinc-400 max-w-md mx-auto mb-6">
              Compose in markdown, pick a segment and a sender, send it.
            </p>
            <%= link_to "Create a campaign →", [:new, :account, team, :campaign], class: "button" %>
          </div>
        <% end %>
      <% end %>

      <% box.actions do %>
        <% unless hide_actions %>
          <% if context == team %>
            <% if can? :create, Campaign.new(team: team) %>
              <%= link_to t('.buttons.new'), [:new, :account, team, :campaign], class: "#{first_button_primary(:campaign)} new" %>
            <% end %>
          <% end %>

          <%# 🚅 super scaffolding will insert new targets one parent action model buttons above this line. %>
          <%# 🚅 super scaffolding will insert new bulk action model buttons above this line. %>
          <%= render "shared/bulk_action_select" if campaigns.any? %>

          <% unless hide_back %>
            <%= link_to t('global.buttons.back'), [:account, context], class: "#{first_button_primary(:campaign)} back" %>
          <% end %>
        <% end %>
      <% end %>

      <% box.raw_footer do %>
        <%# 🚅 super scaffolding will insert new action model index views above this line. %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
