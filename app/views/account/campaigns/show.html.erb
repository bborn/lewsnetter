<%
  recipient_count = @campaign.recipient_count
  segment_name = @campaign.segment&.name
  audience_label = segment_name.present? ? "matching segment \"#{segment_name}\"" : "Everyone subscribed"
  preview_html = @campaign.preview_html
  preview_subscriber = @campaign.team.subscribers.subscribed.order(:id).first
  sent_at_label = @campaign.sent_at&.strftime("%b %-d, %-l:%M %p")
  scheduled_label = @campaign.scheduled_for&.strftime("%b %-d, %-l:%M %p")
  zero_recipients = !recipient_count.nil? && recipient_count.zero?
  send_disabled = !@campaign.sendable? || zero_recipients
  sender_label = @campaign.sender_address&.email.presence || "Default sender"
  template_label = @campaign.email_template&.name.presence || "No template"
  count_for_label = recipient_count || 0
  send_label = recipient_count.nil? ? "Send" : "Send to #{recipient_count} subscriber#{"s" unless recipient_count == 1}"
%>
<%= render 'account/shared/page' do |page| %>
  <%# Visually-hidden page title: the hero block IS the visual title for this
      surface. We keep the H1 for screen readers + document outline so the
      breadcrumb-anchored title partial still has a proper landmark. %>
  <% page.title content_tag(:span, "Campaign overview: #{@campaign.subject.presence || 'untitled draft'}", class: "sr-only") %>
  <% page.body do %>
    <%= cable_ready_updates_for @campaign do %>

      <%# ============================================================
          Editorial hero — the send moment
          ============================================================ %>
      <section class="campaign-show-hero <%= 'campaign-show-hero--sent' if @campaign.sent? %>" aria-labelledby="campaign-subject">
        <div class="campaign-show-hero__eyebrow">
          <span>Campaign</span>
          <span class="campaign-show-hero__id">· <%= @campaign.to_param %></span>
          <%= status_pill(@campaign.status) %>
        </div>

        <h2 id="campaign-subject" class="campaign-show-hero__title">
          <%= @campaign.subject.presence || "(no subject yet)" %>
        </h2>

        <p class="campaign-show-hero__subhead">
          <% if @campaign.sent? && sent_at_label %>
            Sent to <%= count_for_label %> recipient<%= "s" unless count_for_label == 1 %> on <%= sent_at_label %>
          <% elsif @campaign.scheduled? && scheduled_label %>
            Scheduled for <%= scheduled_label %> · <%= count_for_label %> recipient<%= "s" unless count_for_label == 1 %> · from <%= sender_label %>
          <% else %>
            <%= count_for_label %> recipient<%= "s" unless count_for_label == 1 %> · from <%= sender_label %> · using <%= template_label %>
          <% end %>
        </p>

        <% unless @campaign.sent? %>
          <div class="campaign-show-hero__actions">
            <% if @campaign.sendable? && can?(:update, @campaign) %>
              <% if send_disabled %>
                <button type="button"
                        class="btn-editorial btn-editorial--primary"
                        disabled
                        title="<%= zero_recipients ? 'Pick a segment with subscribers in it (or remove the segment) to enable sending.' : 'This campaign is not in a sendable state.' %>">
                  <%= send_label %>
                </button>
              <% else %>
                <% confirm_count = recipient_count || "all subscribed team" %>
                <%= button_to "#{send_label} →".html_safe,
                      send_now_account_campaign_path(@campaign),
                      method: :post,
                      class: "btn-editorial btn-editorial--primary",
                      form: { class: "inline" },
                      data: { turbo_confirm: "About to send to #{confirm_count} subscriber#{"s" unless recipient_count == 1}. Cannot be undone. Continue?" } %>
              <% end %>
            <% end %>

            <% if can?(:update, @campaign) %>
              <%= button_to "Send test to me",
                    test_send_account_campaign_path(@campaign),
                    method: :post,
                    class: "btn-editorial btn-editorial--secondary",
                    form: { class: "inline", data: { turbo: false } },
                    data: { turbo_confirm: "Send a test of \"#{@campaign.subject}\" to #{current_user.email}?" } %>

              <div class="campaign-show-hero__preview-as"
                   data-controller="subscriber-search"
                   data-subscriber-search-team-id-value="<%= @campaign.team_id %>">
                <%= form_with url: preview_as_account_campaign_path(@campaign),
                              method: :post,
                              html: { class: "campaign-show-hero__preview-as-form", data: { turbo: false } } do |f| %>
                  <div class="campaign-show-hero__preview-as-input-wrap">
                    <%= f.text_field :preview_as,
                          placeholder: "Preview as… (email or external_id)",
                          class: "campaign-show-hero__preview-as-input",
                          data: { subscriber_search_target: "input" },
                          aria: { label: "Subscriber email or external ID to render as" } %>
                    <ul data-subscriber-search-target="results"
                        class="campaign-show-hero__preview-as-results hidden"></ul>
                  </div>
                  <%= f.submit "Send as",
                        class: "btn-editorial btn-editorial--ghost",
                        data: { turbo_confirm: "Render this campaign with that subscriber's data and send to #{current_user.email}?" } %>
                <% end %>
              </div>
            <% end %>

          </div>
        <% else %>
          <div class="campaign-show-hero__actions">
            <%= link_to "View postmortem", "#postmortem", class: "btn-editorial btn-editorial--secondary" %>
            <%= link_to "View rendered email", "#campaign-preview", class: "btn-editorial btn-editorial--ghost" %>
          </div>
        <% end %>
      </section>

      <%# ============================================================
          Confidence cue / warning callout
          ============================================================ %>
      <% if @campaign.draft? %>
        <% if zero_recipients %>
          <aside class="campaign-show-callout campaign-show-callout--warn">
            <strong>No recipients yet.</strong> This campaign's segment matches 0 subscribers. Pick a different segment, or remove the segment to send to everyone subscribed.
          </aside>
        <% elsif recipient_count.nil? %>
          <aside class="campaign-show-callout campaign-show-callout--warn">
            <strong>Recipient count unavailable.</strong> The segment's predicate is invalid. Edit the segment to fix.
          </aside>
        <% elsif recipient_count > 0 %>
          <aside class="campaign-show-callout campaign-show-callout--accent">
            <strong>About to send to <%= recipient_count %> subscriber<%= "s" unless recipient_count == 1 %>.</strong>
            <%= audience_label %>. This cannot be undone — bounces and complaints flow through SES + SNS automatically.
          </aside>
        <% end %>
      <% end %>

      <%# ============================================================
          Details — metadata, not a form dump
          ============================================================ %>
      <section class="campaign-show-meta">
        <header class="campaign-show-meta__header">
          <h3 class="campaign-show-meta__title">Details</h3>
          <% if can? :edit, @campaign %>
            <%= link_to "Edit campaign", [:edit, :account, @campaign], class: "campaign-show-meta__edit" %>
          <% end %>
        </header>
        <dl class="campaign-show-meta__grid">
          <div class="campaign-show-meta__row">
            <dt>Subject</dt>
            <dd><%= @campaign.subject.presence || content_tag(:span, "—", class: "campaign-show-meta__empty") %></dd>
          </div>
          <div class="campaign-show-meta__row">
            <dt>Preheader</dt>
            <dd><%= @campaign.preheader.presence || content_tag(:span, "—", class: "campaign-show-meta__empty") %></dd>
          </div>
          <div class="campaign-show-meta__row">
            <dt>Audience</dt>
            <dd>
              <% if segment_name.present? %>
                <%= segment_name %>
              <% else %>
                Everyone subscribed
              <% end %>
              <span class="campaign-show-meta__hint">· <%= count_for_label %> recipient<%= "s" unless count_for_label == 1 %></span>
            </dd>
          </div>
          <div class="campaign-show-meta__row">
            <dt>Sender</dt>
            <dd><span class="campaign-show-meta__mono"><%= sender_label %></span></dd>
          </div>
          <div class="campaign-show-meta__row">
            <dt>Template</dt>
            <dd>
              <% if @campaign.email_template %>
                <%= template_label %>
              <% else %>
                <span class="campaign-show-meta__empty">No template</span>
              <% end %>
            </dd>
          </div>
          <div class="campaign-show-meta__row">
            <dt>Scheduled for</dt>
            <dd>
              <% if scheduled_label %>
                <span class="campaign-show-meta__mono"><%= scheduled_label %></span>
              <% else %>
                <span class="campaign-show-meta__empty">—</span>
              <% end %>
            </dd>
          </div>
        </dl>
      </section>

      <%# ============================================================
          Preview — the rendered email, as an artifact
          ============================================================ %>
      <section id="campaign-preview" class="campaign-show-preview">
        <header class="campaign-show-preview__header">
          <div class="campaign-show-preview__heading">
            <div class="campaign-show-preview__eyebrow">Rendered preview</div>
            <p class="campaign-show-preview__caption">
              <% if preview_subscriber %>
                As seen by <span class="campaign-show-preview__chip"><%= preview_subscriber.email %></span>
              <% else %>
                Placeholder render — no subscribers yet (<span class="campaign-show-preview__chip">preview@example.com</span>)
              <% end %>
            </p>
          </div>
          <% if !@campaign.sent? && can?(:update, @campaign) %>
            <%= button_to "Send test to me",
                  test_send_account_campaign_path(@campaign),
                  method: :post,
                  class: "btn-editorial btn-editorial--ghost",
                  form: { class: "inline", data: { turbo: false } },
                  data: { turbo_confirm: "Send a test of \"#{@campaign.subject}\" to #{current_user.email}?" } %>
          <% end %>
        </header>
        <div class="campaign-show-preview__frame">
          <% if preview_html.present? %>
            <iframe srcdoc="<%= ERB::Util.html_escape(preview_html) %>"
                    class="campaign-show-preview__iframe"
                    sandbox="allow-same-origin"
                    title="Campaign preview"></iframe>
          <% else %>
            <p class="campaign-show-preview__empty">
              Preview could not be rendered — either the campaign has no body and no email template, or the MJML failed to compile. Edit the campaign to fix.
            </p>
          <% end %>
        </div>
      </section>

      <% if @campaign.sent? %>
        <%# Lazy-load the post-send analysis — can take 5-10s with a real LLM. %>
        <%= turbo_frame_tag "postmortem", src: postmortem_account_campaign_path(@campaign), loading: "lazy" do %>
          <aside class="campaign-show-callout campaign-show-callout--neutral">
            Generating AI post-send analysis…
          </aside>
        <% end %>
      <% end %>

      <%# ============================================================
          Footer — quiet back / delete row
          ============================================================ %>
      <footer class="campaign-show-footer">
        <%= link_to t('global.buttons.back'), [:account, @team, :campaigns], class: "campaign-show-footer__link" %>
        <% if can? :destroy, @campaign %>
          <%= button_to t('.buttons.destroy'),
                [:account, @campaign],
                method: :delete,
                class: "campaign-show-footer__danger",
                form: { class: "inline" },
                data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@campaign)) } %>
        <% end %>
      </footer>

      <%# 🚅 super scaffolding will insert new children above this line. %>
    <% end %>
  <% end %>
<% end %>
