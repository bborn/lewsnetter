<%= render "account/shared/page" do |page| %>
  <% page.title "Agent conversations" %>
  <% page.body do %>
    <%= render "account/shared/box" do |box| %>
      <% box.body do %>
        <% if @agent_conversations.any? %>
          <ul class="divide-y divide-zinc-100">
            <% @agent_conversations.each do |c| %>
              <li class="py-3 flex items-center justify-between">
                <div>
                  <%= link_to c.derived_title, [:account, c], class: "text-zinc-900 hover:text-orange-600 font-medium" %>
                  <div class="text-[10px] uppercase tracking-wider text-zinc-500 font-mono mt-1">
                    CONVERSATION · #<%= c.id %> · <%= c.message_count %> MESSAGES · <%= c.updated_at.strftime("%Y-%m-%d") %>
                  </div>
                </div>
                <%= button_to "Delete", [:account, c], method: :delete, data: { turbo_confirm: "Delete this conversation?" }, class: "button button-secondary button-smaller button-danger" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="py-8 text-center text-zinc-500">
            <div class="text-[10px] uppercase tracking-wider font-mono mb-2">NO CONVERSATIONS YET</div>
            <p class="text-sm">Start a new conversation to get help drafting campaigns, building segments, and more.</p>
          </div>
        <% end %>

        <div class="mt-6">
          <%= button_to "Start new conversation", [:account, current_team, :agent_conversations], method: :post, class: "button" %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>
