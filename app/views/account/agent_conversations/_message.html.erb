<%# A single agent message bubble. %>
<%# locals: { message: AgentMessage } %>

<% case message.role %>
<% when "user" %>
  <div class="flex justify-end">
    <div class="bg-zinc-100 text-zinc-900 rounded-lg px-4 py-2 max-w-[85%] text-sm">
      <%= simple_format(message.content) %>
    </div>
  </div>
<% when "assistant" %>
  <div class="flex justify-start">
    <div class="bg-white border border-zinc-200 text-zinc-900 rounded-lg px-4 py-2 max-w-[85%] text-sm">
      <%= simple_format(message.content) %>
    </div>
  </div>
<% when "tool_call" %>
  <div class="text-xs text-zinc-500 font-mono px-2">
    → <%= message.tool_name %>(<%= message.tool_arguments&.to_json %>)
  </div>
<% when "tool_result" %>
  <div class="text-xs text-zinc-500 font-mono px-2">
    ← <%= message.tool_name %>: <%= message.tool_result&.to_json&.truncate(180) %>
  </div>
<% when "error" %>
  <div class="border border-rose-300 bg-rose-50 text-rose-800 rounded px-4 py-2 text-sm">
    <strong><%= message.error_class %>:</strong> <%= message.error_message %>
  </div>
<% end %>
