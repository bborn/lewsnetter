<%# Segment show — ejected from BulletTrain default to render the segment's
    description, compiled SQL predicate, recipient count, sample matching
    subscribers, and any campaigns referencing this segment. %>
<%
  # Run the segment's predicate against the team's subscribers, swallowing
  # any execution errors so the page still renders for a misconfigured
  # segment. If the predicate is blank we show all subscribers (mirrors the
  # behaviour of Segment#applies_to and SendCampaignJob).
  predicate = @segment.predicate
  matching_scope =
    begin
      @segment.applies_to(@team.subscribers)
    rescue Segment::InvalidPredicate, ActiveRecord::StatementInvalid => _e
      nil
    end
  match_count =
    begin
      matching_scope ? matching_scope.count : nil
    rescue ActiveRecord::StatementInvalid
      nil
    end
  sample_subscribers =
    begin
      matching_scope ? matching_scope.limit(5).to_a : []
    rescue ActiveRecord::StatementInvalid
      []
    end
  related_campaigns = @segment.respond_to?(:campaigns) ? @segment.campaigns.to_a : []
%>

<%= render 'account/shared/page' do |page| %>
  <% page.title @segment.name %>
  <% page.body do %>
    <%= cable_ready_updates_for @segment do %>
    <div class="space-y-6">

      <%# Header card: name + description %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title @segment.name %>
        <% box.description do %>
          Saved audience query. The predicate below is what we run against your
          subscribers when a campaign sends.
        <% end %>

        <% box.body do %>
          <dl class="space-y-3">
            <% if @segment.natural_language_source.present? %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Description</dt>
                <dd class="mt-1 text-sm"><%= @segment.natural_language_source %></dd>
              </div>
            <% end %>
          </dl>
        <% end %>

        <% box.actions do %>
          <%= link_to "Edit segment", [:edit, :account, @segment], class: first_button_primary if can? :edit, @segment %>
          <%= button_to "Remove segment", [:account, @segment],
                method: :delete,
                class: first_button_primary,
                data: { turbo_confirm: t('.buttons.confirmations.destroy', model_locales(@segment)) } if can? :destroy, @segment %>
          <%= link_to t('global.buttons.back'), [:account, @team, :segments], class: first_button_primary %>
        <% end %>
      <% end %>

      <%# Predicate card %>
      <%= render 'account/shared/box', divider: true do |box| %>
        <% box.title "Predicate" %>
        <% box.description do %>
          Compiled SQL filter applied to your subscribers when this segment is
          used. Scoped to subscribers columns + custom_attributes only.
        <% end %>

        <% box.body do %>
          <% if predicate.present? %>
            <pre class="bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-md p-4 overflow-x-auto whitespace-pre-wrap break-words"><code class="font-mono text-[12px] text-zinc-700 dark:text-zinc-300"><%= predicate %></code></pre>
          <% else %>
            <div class="text-center px-6 py-10">
              <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">No predicate</div>
              <p class="text-zinc-600 dark:text-zinc-400 max-w-md mx-auto mb-5">
                No predicate set yet — tell the AI translator who this segment
                targets (e.g. "brand-tenant managers active in the last 30
                days") or write SQL against the subscribers table directly.
              </p>
              <% if can? :edit, @segment %>
                <%= link_to "Edit segment →", [:edit, :account, @segment], class: "button" %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>

      <%# Audience: match count + paginated browseable table — same
          partial the team-wide Subscribers index uses, scoped to the
          segment's matching set so users can validate the predicate by
          inspecting actual rows. %>
      <% if match_count.nil? %>
        <%= render 'account/shared/box', divider: true do |box| %>
          <% box.title "Audience" %>
          <% box.body do %>
            <div class="rounded-md border border-rose-200 dark:border-rose-900/60 bg-rose-50 dark:bg-rose-950/30 px-4 py-3">
              <div class="font-mono text-[11px] uppercase tracking-widest text-rose-700 dark:text-rose-400 mb-1">Predicate error</div>
              <p class="text-sm text-rose-700 dark:text-rose-300">
                Couldn't run this segment's predicate — it may reference invalid
                columns. Edit the segment to fix it.
              </p>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <%# Sort dropdown on top of the table — re-renders the page with
            the chosen ordering. Defaults to most-recently-added first so
            new subscribers are easy to spot. %>
        <%
          sort_options = {
            "created_at desc" => "Newest first",
            "created_at asc"  => "Oldest first",
            "external_id asc" => "External ID (A→Z)",
            "external_id desc"=> "External ID (Z→A)"
          }
          current_sort = sort_options.key?(params[:sort]) ? params[:sort] : "created_at desc"
          sort_col, sort_dir = current_sort.split(" ", 2)
          sorted_scope = matching_scope.reorder("#{sort_col} #{sort_dir}, id #{sort_dir}")
        %>

        <div class="px-1 -mb-2 flex items-center justify-between gap-3">
          <p class="text-sm text-zinc-700 dark:text-zinc-300 segment-show-audience-count">
            <strong><%= number_with_delimiter(match_count) %></strong>
            <%= "subscriber".pluralize(match_count) %> match this segment.
          </p>
          <form method="get" action="<%= url_for([:account, @segment]) %>" class="flex items-center gap-2 text-sm">
            <label for="segment-sort" class="text-zinc-500 dark:text-zinc-400 font-mono text-[11px] uppercase tracking-widest">Sort</label>
            <select id="segment-sort" name="sort" onchange="this.form.submit()"
                    class="rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-sm py-1.5 px-2">
              <% sort_options.each do |value, label| %>
                <option value="<%= value %>" <%= "selected" if value == current_sort %>><%= label %></option>
              <% end %>
            </select>
          </form>
        </div>

        <%= render 'account/subscribers/index',
              context: @segment,
              subscribers: sorted_scope,
              hide_actions: true,
              hide_back: true %>
      <% end %>

      <%# Used-in-campaigns card: only render if Campaign belongs_to segment %>
      <% if related_campaigns.any? %>
        <%= render 'account/shared/box', divider: true do |box| %>
          <% box.title "Used in" %>
          <% box.description do %>
            Campaigns that target this segment when they send.
          <% end %>

          <% box.body do %>
            <ul class="text-sm space-y-1">
              <% related_campaigns.each do |campaign| %>
                <li>
                  <%= link_to campaign.subject.presence || "Untitled campaign",
                        [:account, campaign],
                        class: "text-blue-600 hover:underline" %>
                  <% if campaign.respond_to?(:status) %>
                    <span class="ml-2 text-xs text-gray-500"><%= campaign.status %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% end %>
        <% end %>
      <% end %>

      <%# Audit history — every create/update/destroy lands here. %>
      <%= render "account/shared/history", record: @segment %>

      <%# Footer metadata %>
      <p class="text-xs text-gray-500 mt-3">
        Created <%= l(@segment.created_at, format: :long) if @segment.created_at %>
        <% if @segment.updated_at && @segment.updated_at != @segment.created_at %>
          · updated <%= l(@segment.updated_at, format: :long) %>
        <% end %>
      </p>

    </div>
    <% end %>

    <%# 🚅 super scaffolding will insert new children above this line. %>
  <% end %>
<% end %>
