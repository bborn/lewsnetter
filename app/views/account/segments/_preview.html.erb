<%# Renders inside #segment_preview turbo-frame.
   Locals: result (AI::SegmentTranslator::Result), natural_language (String). %>
<%= turbo_frame_tag "segment_preview" do %>
  <div class="p-4 my-4 border rounded-md bg-gray-50 dark:bg-sky-950 dark:border-sky-800">
    <h3 class="text-lg font-semibold mb-2">
      AI Segment Preview
      <% if result.respond_to?(:stub?) && result.stub? %>
        <span class="text-xs font-normal text-gray-500 ml-2">(stub mode — no LLM call)</span>
      <% end %>
    </h3>

    <% if result.errors.present? %>
      <div class="text-red-600 text-sm mb-2">
        <ul class="list-disc list-inside">
          <% result.errors.each do |err| %>
            <li><%= err %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <p class="text-sm mb-2">
      <strong>Description:</strong>
      <%= result.human_description %>
    </p>

    <p class="text-sm mb-2">
      <strong>Predicate:</strong>
      <code class="font-mono text-xs"><%= result.sql_predicate %></code>
    </p>

    <p class="text-sm mb-2">
      <strong>Estimated count:</strong>
      <%= result.estimated_count %> subscribers
    </p>

    <% if result.sample_subscribers.any? %>
      <details class="mt-2">
        <summary class="cursor-pointer text-sm font-medium">Sample subscribers (<%= result.sample_subscribers.size %>)</summary>
        <ul class="list-disc list-inside text-sm mt-1">
          <% result.sample_subscribers.each do |s| %>
            <li><%= s.email %><%= " (#{s.name})" if s.name.present? %></li>
          <% end %>
        </ul>
      </details>
    <% end %>

    <% if result.sql_predicate.present? && result.errors.blank? %>
      <p class="text-xs text-gray-500 mt-2">
        Copy this predicate into the "Natural language source" field, or save the segment with this description.
      </p>
    <% end %>
  </div>
<% end %>
