<% segments = segments.accessible_by(current_ability) %>
<% team = @team %>
<% context ||= team %>
<% collection ||= :segments %>
<% hide_actions ||= false %>
<% hide_back ||= false %>

<% pagy ||= nil %>
<% pagy, segments = pagy(segments, page_param: :segments_page) unless pagy %>

<%= action_model_select_controller do %>
  <% cable_ready_updates_for context, collection do %>
    <%= render 'account/shared/box', pagy: pagy do |box| %>
      <% box.title t(".contexts.#{context.class.name.underscore}.header") %>
      <% box.description do %>
        <%= t(".contexts.#{context.class.name.underscore}.description#{"_empty" unless segments.any?}") %>
        <%= render "shared/limits/index", model: segments.model %>
      <% end %>

      <% box.table do %>
        <% if segments.any? %>
          <table class="table">
            <thead>
              <tr>
                <%= render "shared/tables/select_all" %>
                <th><%= t('.fields.name.heading') %></th>
                <%# 🚅 super scaffolding will insert new field headers above this line. %>
                <th><%= t('.fields.created_at.heading') %></th>
                <th class="text-right"></th>
              </tr>
            </thead>
            <tbody>
              <%= render partial: 'account/segments/segment', collection: segments %>
            </tbody>
          </table>
        <% elsif context == team && can?(:create, Segment.new(team: team)) %>
          <div class="text-center py-12 px-6">
            <div class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">No segments yet</div>
            <h3 class="text-[18px] font-semibold text-zinc-900 dark:text-zinc-100 mb-2">Slice your audience</h3>
            <p class="text-zinc-500 dark:text-zinc-400 max-w-md mx-auto mb-6">
              Save a query — describe it in English and let the AI translator
              compile it, or write SQL directly. Campaigns target one segment.
            </p>
            <%= link_to "Create a segment →", [:new, :account, team, :segment], class: "button" %>
          </div>
        <% end %>
      <% end %>

      <% box.actions do %>
        <% unless hide_actions %>
          <% if context == team %>
            <% if can? :create, Segment.new(team: team) %>
              <%= link_to t('.buttons.new'), [:new, :account, team, :segment], class: "#{first_button_primary(:segment)} new" %>
            <% end %>
          <% end %>

          <%# 🚅 super scaffolding will insert new targets one parent action model buttons above this line. %>
          <%# 🚅 super scaffolding will insert new bulk action model buttons above this line. %>
          <%= render "shared/bulk_action_select" if segments.any? %>

          <% unless hide_back %>
            <%= link_to t('global.buttons.back'), [:account, context], class: "#{first_button_primary(:segment)} back" %>
          <% end %>
        <% end %>
      <% end %>

      <% box.raw_footer do %>
        <%# 🚅 super scaffolding will insert new action model index views above this line. %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
