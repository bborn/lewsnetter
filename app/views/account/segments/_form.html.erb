<% cancel_path ||= segment.persisted? ? [:account, segment] : [:account, @team, :segments] %>
<%
  fields_json    = ::Segments::FieldRegistry.new(team: @team).call
  operators_json = ::Segments::PredicateCompiler::OPERATORS
  preview_url = preview_account_team_segments_path(@team)
%>

<%= form_with model: segment,
              url: (segment.persisted? ? [:account, segment] : [:account, @team, :segments]),
              class: 'form' do |form| %>
  <%= render "shared/limits/form", form: form, cancel_path: cancel_path do %>
    <%= render 'account/shared/forms/errors', form: form %>

    <% with_field_settings form: form do %>
      <%= render 'shared/fields/text_field', method: :name, options: {autofocus: true} %>
    <% end %>

    <div class="form-group">
      <%= form.label :natural_language_source, "Description", class: "block text-sm font-medium mb-1" %>
      <%= form.text_area :natural_language_source,
            rows: 2,
            placeholder: "What this segment is for (optional, just a note for your team).",
            class: "w-full p-2 border rounded-md" %>
    </div>

    <%# Visual rule builder. Renders a recursive tree of AND/OR groups + %>
    <%# rules, live-previews matching subscribers via /segments/preview, %>
    <%# serializes the tree into the hidden segment[rules] input on submit. %>
    <div class="form-group">
      <label class="block text-sm font-medium mb-2">Rules</label>
      <div data-controller="segments-builder"
           data-segments-builder-tree-value="<%= segment.rules.to_json %>"
           data-segments-builder-fields-value="<%= fields_json.to_json %>"
           data-segments-builder-operators-value="<%= operators_json.to_json %>"
           data-segments-builder-preview-url-value="<%= preview_url %>"
           data-segments-builder-csrf-value="<%= form_authenticity_token %>"
           class="space-y-4">
        <div class="space-y-3">
          <div data-segments-builder-target="tree"></div>
          <%= form.hidden_field :rules, value: segment.rules.to_json,
                data: {segments_builder_target: "hiddenInput"} %>
        </div>
        <%# Matching count + sample below the rules, full width. %>
        <div data-segments-builder-target="preview"></div>
      </div>
    </div>

    <%# 🚅 super scaffolding will insert new fields above this line. %>

    <div class="buttons">
      <%= form.submit (form.object.persisted? ? t('.buttons.update') : t('.buttons.create')), class: "button" %>
      <%= link_to t('global.buttons.cancel'), cancel_path, class: "button-secondary" %>
    </div>
  <% end %>
<% end %>
