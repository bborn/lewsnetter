<%#
  Recipient-facing unsubscribe layout. Intentionally lightweight: no
  authenticated nav, no JS app dependencies. Looks like an email landing
  page rather than the admin shell.
%>
<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <%= render 'shared/layouts/head' %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-700 antialiased font-sans">
    <div class="min-h-screen flex flex-col">
      <header class="border-b border-slate-200 bg-white">
        <div class="max-w-3xl mx-auto px-6 py-5 flex items-center">
          <span class="text-lg font-semibold tracking-tight text-slate-900">
            <%= @unsubscribe_team_name.presence || t('application.name') %>
          </span>
        </div>
      </header>

      <main class="flex-1 flex items-start sm:items-center justify-center px-6 py-12 sm:py-20">
        <div class="w-full max-w-xl bg-white rounded-2xl shadow-sm border border-slate-200 px-6 sm:px-10 py-10 sm:py-14">
          <%= yield %>
        </div>
      </main>

      <footer class="py-6 text-center text-xs text-slate-400">
        Powered by <%= t('application.name') %>
      </footer>
    </div>
  </body>
</html>
