<%# Lewsnetter operator dashboard — landed-on by default via config.home_path
    in config/initializers/avo.rb. Renders three panels inside Avo's chrome:
      1. Signups (24h / 7d / 30d)
      2. Counts across the post-BulletTrain entity surface
      3. The 25 most-recent users
    Pure ERB + Tailwind — no Avo Pro dashboard gem required. %>
<div class="flex flex-col space-y-6">
  <%= render Avo::PanelComponent.new(name: "Signups", display_breadcrumbs: true) do |c| %>
    <% c.with_body do %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-6">
        <div class="rounded-lg border border-gray-200 p-4">
          <div class="text-xs uppercase tracking-wide text-gray-500">Last 24h</div>
          <div class="text-3xl font-semibold mt-1"><%= number_with_delimiter(@signups_24h) %></div>
        </div>
        <div class="rounded-lg border border-gray-200 p-4">
          <div class="text-xs uppercase tracking-wide text-gray-500">Last 7 days</div>
          <div class="text-3xl font-semibold mt-1"><%= number_with_delimiter(@signups_7d) %></div>
        </div>
        <div class="rounded-lg border border-gray-200 p-4">
          <div class="text-xs uppercase tracking-wide text-gray-500">Last 30 days</div>
          <div class="text-3xl font-semibold mt-1"><%= number_with_delimiter(@signups_30d) %></div>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render Avo::PanelComponent.new(name: "Platform counts") do |c| %>
    <% c.with_body do %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 p-6 text-sm">
        <% [
          ["Users", @counts[:users]],
          ["Teams", @counts[:teams]],
          ["Subscribers", "#{number_with_delimiter(@counts[:subscribers])} (#{number_with_delimiter(@counts[:subscribed_subscribers])} subscribed)"],
          ["Companies", @counts[:companies]],
          ["Segments", @counts[:segments]],
          ["Email templates", @counts[:email_templates]],
          ["Campaigns", "#{number_with_delimiter(@counts[:campaigns])} (#{number_with_delimiter(@counts[:campaigns_sent])} sent)"],
          ["Deliveries", @counts[:deliveries]],
          ["Suppressions", @counts[:suppressions]],
          ["SES configurations", "#{number_with_delimiter(@counts[:ses_configurations])} (#{number_with_delimiter(@counts[:verified_ses_configurations])} verified)"],
          ["SES domains", "#{number_with_delimiter(@counts[:ses_domains])} (#{number_with_delimiter(@counts[:verified_ses_domains])} verified)"]
        ].each do |label, value| %>
          <div class="rounded border border-gray-200 px-3 py-2">
            <div class="text-xs uppercase tracking-wide text-gray-500"><%= label %></div>
            <div class="text-lg font-medium mt-1">
              <% if value.is_a?(Numeric) %>
                <%= number_with_delimiter(value) %>
              <% else %>
                <%= value %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render Avo::PanelComponent.new(name: "Recent signups") do |c| %>
    <% c.with_body do %>
      <div class="p-6">
        <% if @recent_users.any? %>
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-left text-xs uppercase tracking-wide text-gray-500 border-b border-gray-200">
                <th class="py-2 pr-4">When</th>
                <th class="py-2 pr-4">Email</th>
                <th class="py-2 pr-4">Name</th>
                <th class="py-2 pr-4">Current team</th>
                <th class="py-2 pr-4"></th>
              </tr>
            </thead>
            <tbody>
              <% @recent_users.each do |user| %>
                <tr class="border-b border-gray-100">
                  <td class="py-2 pr-4 text-gray-600"><%= time_ago_in_words(user.created_at) %> ago</td>
                  <td class="py-2 pr-4"><%= user.email %></td>
                  <td class="py-2 pr-4"><%= user.full_name.presence || "—" %></td>
                  <td class="py-2 pr-4"><%= user.current_team&.name || "—" %></td>
                  <td class="py-2 pr-4">
                    <%# Avo generates one named route per resource, e.g.
                        resources_user_path(user). Using it directly is
                        more robust than the polymorphic resource_path
                        helper, which has a kwargs surface that varies
                        across Avo versions. %>
                    <%= link_to "Open", avo.resources_user_path(user), class: "text-blue-600 hover:underline" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="text-gray-500">No signups yet.</p>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
