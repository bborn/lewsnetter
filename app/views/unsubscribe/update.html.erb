<% if @status == :ok %>
  <div class="text-center">
    <div class="mx-auto mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-slate-900 mb-3">
      You've been unsubscribed.
    </h1>

    <p class="text-slate-600 leading-relaxed mb-8">
      We've removed
      <span class="font-medium text-slate-800"><%= @subscriber.email %></span>
      from <%= @team&.name.presence || t('application.name') %>'s mailing list.
      You won't receive any more campaigns.
    </p>

    <p class="text-sm text-slate-500">
      Changed your mind?
      <%# TODO: replace mailto with /resubscribe/:token route once resubscribe flow is built. %>
      <a href="mailto:bruno@influencekit.com?subject=Re-subscribe%20me&body=Please%20re-subscribe%20<%= CGI.escape(@subscriber.email) %>%20to%20<%= CGI.escape(@team&.name || 'the') %>%20newsletter."
         class="font-medium text-blue-600 hover:text-blue-700 underline-offset-2 hover:underline">
        Re-subscribe &rarr;
      </a>
    </p>
  </div>
<% else %>
  <div class="text-center">
    <div class="mx-auto mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-amber-100 text-amber-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>

    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-slate-900 mb-3">
      That link's expired.
    </h1>

    <p class="text-slate-600 leading-relaxed">
      Reply to your most recent email and we'll remove you manually.
    </p>
  </div>
<% end %>
