<% if @status == :ok %>
  <div class="text-center">
    <div class="font-mono text-[11px] uppercase tracking-widest text-emerald-600 mb-3">Unsubscribed</div>

    <h1 class="text-[28px] sm:text-[32px] font-semibold tracking-tight text-zinc-900 mb-4 leading-tight">
      You've been unsubscribed.
    </h1>

    <p class="text-zinc-600 leading-relaxed mb-8 max-w-md mx-auto">
      We've removed
      <span class="font-medium text-zinc-900"><%= @subscriber.email %></span>
      from <%= @team&.name.presence || t('application.name') %>'s mailing list.
      You won't receive any more campaigns.
    </p>

    <p class="text-sm text-zinc-500">
      Changed your mind?
      <%# TODO: replace mailto with /resubscribe/:token route once resubscribe flow is built. %>
      <a href="mailto:bruno@influencekit.com?subject=Re-subscribe%20me&body=Please%20re-subscribe%20<%= CGI.escape(@subscriber.email) %>%20to%20<%= CGI.escape(@team&.name || 'the') %>%20newsletter."
         class="font-medium text-zinc-900 hover:text-primary-600 underline-offset-2 underline">
        Re-subscribe →
      </a>
    </p>
  </div>
<% else %>
  <div class="text-center">
    <div class="font-mono text-[11px] uppercase tracking-widest text-amber-600 mb-3">Link expired</div>

    <h1 class="text-[28px] sm:text-[32px] font-semibold tracking-tight text-zinc-900 mb-4 leading-tight">
      That link's expired.
    </h1>

    <p class="text-zinc-600 leading-relaxed max-w-md mx-auto">
      Reply to your most recent email and we'll remove you manually.
    </p>
  </div>
<% end %>
