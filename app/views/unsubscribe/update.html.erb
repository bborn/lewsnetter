<div class="max-w-2xl mx-auto py-16 px-6 text-center">
  <% if @status == :ok %>
    <h1 class="text-2xl font-semibold mb-4">You're unsubscribed</h1>
    <p class="text-gray-600">
      <%= @subscriber.email %> will no longer receive newsletter emails from us.
    </p>
  <% else %>
    <h1 class="text-2xl font-semibold mb-4">Unsubscribe link is invalid</h1>
    <p class="text-gray-600">
      We couldn't find a subscriber for this link. If you keep getting emails,
      reply to the latest message and we'll remove you manually.
    </p>
  <% end %>
</div>
